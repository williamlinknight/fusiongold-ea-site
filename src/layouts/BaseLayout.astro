---
export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const siteBase = '/fusiongold-ea-site';
// debug
---

<!DOCTYPE html>
<html lang="ja" class="jp-mode">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FusionGold M5</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="XAUUSD EA, ゴールド自動売買, MT5 EA, 金EA, FusionGold M5, 物々交換" />
  <link rel="canonical" href="https://williamlinknight.github.io/fusiongold-ea-site/" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://williamlinknight.github.io/fusiongold-ea-site/" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="FusionGold M5" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="google-site-verification" content="FGKyrzvPC8r6Bdi7XpcgyVYiXFVDdTatDMa5SmlIBoY" />
  <!-- JSON-LD: WebSite (global) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "FusionGold M5",
    "url": "https://williamlinknight.github.io/fusiongold-ea-site",
    "alternateName": "XAUUSD ゴールドEA",
    "description": "XAUUSD（ゴールド）M5専用自動売買EA。ADX+4バケットスコアリング+H4ゾーンフィルター搭載。"
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --gold: #D4AF37;
      --gold-light: #F0D060;
      --gold-dark: #B8962A;
      --bg: #0D0D1A;
      --bg-card: #16162A;
      --bg-card-hover: #1E1E38;
      --text: #E8E6E3;
      --text-muted: #8A8A9A;
      --border: #2A2A44;
      --accent-green: #34D399;
      --accent-red: #F87171;
      --radius: 12px;
      --max-w: 1024px;
      --transition: 0.3s ease;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--gold); text-decoration: none; transition: var(--transition); }
    a:hover { opacity: .85; }
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }
    .nav {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      position: sticky; top:0; z-index:100;
    }
    .nav a { font-size: 0.85rem; }
    .nav .logo { font-weight: 700; color: var(--gold); font-size: 1.05rem; }
    .nav .links { margin-left: auto; display: flex; gap: 16px; align-items: center; }
    .lang-toggle { display:flex; gap:2px; margin-left:12px; }
    .lang-btn {
      padding:4px 10px; border-radius:6px; font-size:0.8rem; font-weight:600;
      cursor:pointer; border:1px solid var(--border); background:transparent; color:var(--text-muted);
      transition: var(--transition);
    }
    .lang-btn.active { background:var(--gold); color:#0D0D1A; border-color:var(--gold); }
    .lang-btn:hover:not(.active) { color: var(--gold); }
    /* Language content block visibility */
    html.jp-mode .lang-en { display: none !important; }
    html.en-mode .lang-jp { display: none !important; }
    .demo-nav-btn {
      display:inline-block; padding:4px 12px; border-radius:6px;
      font-size:0.8rem; font-weight:700; text-decoration:none;
      background:linear-gradient(135deg,var(--gold),var(--gold-dark)); color:#0D0D1A;
      transition:var(--transition);
    }
    .demo-nav-btn:hover { opacity:.85; transform:translateY(-1px); box-shadow:0 2px 12px rgba(212,175,55,.3); }
    .dropdown { position:relative; display:inline-flex; }
    .dropdown-trigger {
      font-size:0.85rem; cursor:pointer; color:var(--text-muted);
      transition:var(--transition); padding:0 4px;
    }
    .dropdown-trigger:hover, .dropdown:hover .dropdown-trigger { color:var(--gold); }
    .dropdown .arrow { font-size:0.65rem; margin-left:2px; }
    .dropdown-content {
      display:none; position:absolute; top:100%; left:50%; transform:translateX(-50%);
      background:var(--bg-card); border:1px solid var(--border);
      border-radius:8px; min-width:150px; padding:6px 0;
      z-index:100; box-shadow:0 8px 24px rgba(0,0,0,.4);
    }
    .dropdown-content a {
      display:block; padding:8px 16px; font-size:0.8rem;
      color:var(--text-muted); white-space:nowrap; text-decoration:none;
    }
    .dropdown-content a:hover { background:var(--bg-card-hover); color:var(--gold); }
    .dropdown:hover .dropdown-content { display:block; }

    /* Hamburger */
    .hamburger {
      display:none; flex-direction:column; gap:4px;
      background:none; border:none; cursor:pointer;
      padding:4px; z-index:101;
    }
    .hamburger span {
      display:block; width:22px; height:2px;
      background:var(--text); border-radius:2px;
      transition:var(--transition);
    }
    .hamburger.open span:nth-child(1) { transform:rotate(45deg) translate(4px,4px); }
    .hamburger.open span:nth-child(2) { opacity:0; }
    .hamburger.open span:nth-child(3) { transform:rotate(-45deg) translate(4px,-4px); }

    /* Mobile nav */
    @media (max-width:820px) {
      .links { display:none; }
      .links.open { display:flex; flex-direction:column; position:absolute; top:100%; left:0; right:0; background:var(--bg-card); border-bottom:1px solid var(--border); padding:12px; z-index:100; box-shadow:0 8px 24px rgba(0,0,0,.3); }
      .links.open > a, .links.open .dropdown-trigger { padding:10px 0; width:100%; }
      .links.open .dropdown { flex-direction:column; width:100%; }
      .links.open .dropdown-content { position:static; transform:none; box-shadow:none; border:none; background:var(--bg); margin:4px 0 4px 16px; border-radius:6px; display:none; }
      .links.open .dropdown.open .dropdown-content { display:block; }
      .links.open .lang-toggle { padding-top:8px; }
      .hamburger { display:flex; }
      .top-bar { display:none; }
    }
    .btn {
      display: inline-block; padding: 12px 32px; border-radius: 8px;
      font-weight: 600; font-size: 0.95rem; cursor: pointer; border: none;
      transition: var(--transition);
    }
    .btn-gold {
      background: linear-gradient(135deg, var(--gold), var(--gold-dark));
      color: #0D0D1A;
    }
    .btn-gold:hover { background: var(--gold-dark); transform: translateY(-1px); box-shadow: 0 4px 20px rgba(212,175,55,.3); }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
    .author-card { display: flex; gap: 24px; align-items: flex-start; background: var(--bg); border-radius: var(--radius); padding: 32px; border: 1px solid var(--border); }
    .author-avatar { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg,var(--gold),var(--gold-dark)); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; font-weight: 800; color: #111; flex-shrink: 0; }
    @media (max-width: 560px) { .author-card { flex-direction: column; align-items: center; text-align: center; } }
    .btn-outline {
      background: transparent; border: 2px solid var(--gold); color: var(--gold);
    }
    .btn-outline:hover { background: var(--gold); color: #0D0D1A; }
    .section { padding: 80px 0; }
    .section-title {
      font-size: 1.8rem; font-weight: 700; color: var(--gold);
      text-align: center; margin-bottom: 8px;
    }
    .section-sub { text-align: center; color: var(--text-muted); margin-bottom: 48px; font-size: 0.95rem; }
    .hero {
      padding: 100px 0 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; top: -50%; left: -50%;
      width: 200%; height: 200%;
      background: radial-gradient(ellipse at center, rgba(212,175,55,0.06), transparent 70%);
      animation: float 20s ease-in-out infinite;
    }
    @keyframes float { 0%,100% { transform:translate(0,0); } 50% { transform:translate(-20px,-20px); } }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-size: 3rem; font-weight: 800; color: var(--gold); margin-bottom: 12px; }
    .hero .subtitle { font-size: 1.15rem; color: var(--text-muted); margin-bottom: 8px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .hero .subtitle2 { font-size: 0.95rem; color: var(--text-muted); opacity: .7; margin-bottom: 28px; }
    .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .demo-link { display: inline-flex; align-items: center; gap: 8px; color: var(--gold); text-decoration: none; margin-top: 28px; font-size: 0.9rem; }
    .demo-link:hover { text-decoration: underline; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .feature-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px; transition: var(--transition);
    }
    .feature-card:hover { background: var(--bg-card-hover); border-color: var(--gold-dark); transform: translateY(-4px); }
    .feature-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
    .feature-card h3 { font-size: 1.1rem; color: var(--gold); margin-bottom: 8px; }
    .feature-card p { color: var(--text-muted); font-size: 0.9rem; }
    .perf-table-wrap { overflow-x: auto; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin-bottom: 16px; }
    .perf-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .perf-table th, .perf-table td { padding: 10px 16px; text-align: center; border-bottom: 1px solid var(--border); }
    .perf-table th { color: var(--gold); font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .perf-table td { color: var(--text-muted); }
    .perf-table .highlight { color: var(--accent-green); font-weight: 600; }
    .footer { text-align: center; padding: 32px 0; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.8rem; }
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
    .brief-cards { display: flex; flex-wrap: wrap; gap: 16px; padding: 8px 0; }
    .brief-card { flex: 1; min-width: 140px; text-align: center; padding: 12px; background: var(--bg); border-radius: 8px; }
    .brief-card .label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 4px; }
    .brief-card .value { font-size: 1.3rem; font-weight: 800; }
    .brief-card .sub { font-size: 0.75rem; color: var(--text-muted); }
    .brief-card .green { color: var(--accent-green); }
    .brief-card .red { color: var(--accent-red); }
    .brief-card .big { font-size: 1.8rem; color: var(--gold); }
    .contact-form { max-width: 560px; margin: 0 auto; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 6px; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%; padding: 10px 14px; background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text); font-size: 0.95rem; font-family: inherit;
      transition: var(--transition);
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
      outline: none; border-color: var(--gold); box-shadow: 0 0 0 3px rgba(212,175,55,0.15);
    }
    .form-group textarea { min-height: 120px; resize: vertical; }
    .form-submit { width: 100%; }
    .top-bar {
      background: var(--bg-card); border-bottom: 1px solid var(--border);
      padding: 8px 0; text-align: center; font-size: 0.8rem;
    }
    .cta-section { text-align: center; background: var(--bg-card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    p { margin-bottom: 0; }
  </style>
</head>
<body>

  <div class="top-bar">
    <a href={siteBase + '/'} style="color:var(--text-muted);text-decoration:none;">FusionGold M5</a>
  </div>

  <nav class="nav">
    <a href={siteBase + '/'} class="logo">FusionGold M5</a>
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="links" id="navLinks">
      <a href={siteBase + '/'} data-i18n="nav-home">ホーム</a>

      <div class="dropdown">
        <span class="dropdown-trigger" data-i18n="nav-product">製品 <span class="arrow">▾</span></span>
        <div class="dropdown-content">
          <a href={siteBase + '/live/'} data-i18n="nav-live">パフォーマンス</a>
          <a href={siteBase + '/backtest/'} data-i18n="nav-backtest">バックテスト</a>
          <a href={siteBase + '/setup/'} data-i18n="nav-setup">セットアップ</a>
          <a href={siteBase + '/strategy/'} data-i18n="nav-strategy">戦略</a>
        </div>
      </div>

      <div class="dropdown">
        <span class="dropdown-trigger" data-i18n="nav-learn">学ぶ <span class="arrow">▾</span></span>
        <div class="dropdown-content">
          <a href={siteBase + '/glossary/'} data-i18n="nav-glossary">用語集</a>
          <a href={siteBase + '/faq/'} data-i18n="nav-faq">FAQ</a>
        </div>
      </div>

      <a href={siteBase + '/blog/'} data-i18n="nav-blog">ブログ</a>

      <a href={siteBase + '/brief/'} data-i18n="nav-brief">デイリー分析</a>
      <a href={siteBase + '/contact/'} data-i18n="nav-contact">お問い合わせ</a>
      <a href={siteBase + '/demo/'} class="demo-nav-btn">デモ</a>
      <div class="lang-toggle" role="radiogroup" aria-label="Language">
        <button class="lang-btn active" data-lang="JP" role="radio" aria-checked="true">JP</button>
        <button class="lang-btn" data-lang="EN" role="radio" aria-checked="false">EN</button>
      </div>
    </div>
  </nav>

  <slot />

  <footer class="footer">
    <div class="container" style="display:flex;flex-direction:column;gap:8px;">
      <p data-i18n="footer-text">© 2026 FusionGold M5 · XAUUSD専用EA</p>
      <div style="display:flex;gap:16px;justify-content:center;font-size:0.8rem;">
        <a href={siteBase + '/disclaimer/'} style="color:var(--text-muted);text-decoration:underline;" data-i18n="footer-disclaimer">免責事項</a>
        <a href={siteBase + '/privacy/'} style="color:var(--text-muted);text-decoration:underline;" data-i18n="footer-privacy">プライバシーポリシー</a>
      </div>
    </div>
  </footer>

