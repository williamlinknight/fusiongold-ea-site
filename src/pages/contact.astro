---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteBase = '/fusiongold-ea-site';
---

<BaseLayout title="お問い合わせ | FusionGold M5" description="FusionGold M5 のお問い合わせ。デモ口座、物々交換など。">

  <div class="container" style="padding-top:40px;padding-bottom:60px;">
    <h1 style="color:var(--gold);margin-bottom:8px;text-align:center;" data-i18n="contact-title">お問い合わせ</h1>
    <p style="color:var(--text-muted);margin-bottom:32px;text-align:center;" data-i18n="contact-sub">お問い合わせ、デモ口座のリクエスト、物々交換の提案など、お気軽にどうぞ。</p>

    <form id="contact-form" class="contact-form">
      <div class="form-group">
        <label for="name" data-i18n="contact-name">お名前</label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="form-group">
        <label for="email" data-i18n="contact-email">メールアドレス</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com">
      </div>
      <div class="form-group">
        <label for="type" data-i18n="contact-type">お問い合わせ種別</label>
        <select id="type" name="type">
          <option value="barter" selected data-i18n="ct-type2">物々交換について</option>
          <option value="demo" data-i18n="ct-type3">デモ口座について</option>
          <option value="other" data-i18n="ct-type4">その他</option>
        </select>
      </div>
      <div class="form-group">
        <label for="message" data-i18n="contact-msg">メッセージ</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <div class="form-group" style="display:flex;align-items:flex-start;gap:8px;margin-bottom:20px;">
        <input type="checkbox" id="disclaimer_agree" name="disclaimer_agree" required style="margin-top:4px;width:auto;flex-shrink:0;">
        <label for="disclaimer_agree" style="font-size:0.8rem;color:var(--text-muted);font-weight:400;">
          <a href={siteBase + '/disclaimer/'} style="color:var(--gold);" target="_blank">免責事項</a>に同意し、外国為替証拠金取引のリスクを理解した上でお問い合わせします。
        </label>
      </div>
      <button type="submit" class="btn btn-gold form-submit" data-i18n="contact-submit">送信する</button>
      <p style="margin-top:12px;font-size:0.8rem;color:var(--text-muted);" data-i18n="contact-note">※お返事までに1-2営業日いただく場合がございます。</p>
    </form>

    <script>
      document.getElementById('contact-form')?.addEventListener('submit', function(e) {
        e.preventDefault();
        alert('お問い合わせいただきありがとうございます。近日中にご連絡いたします。');
      });
    </script>
  </div>
</BaseLayout>
