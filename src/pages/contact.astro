---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteBase = '/fusiongold-ea-site';
---

<BaseLayout title="お問い合わせ | FusionGold M5" description="FusionGold M5 のお問い合わせ。デモ口座、物々交換など。">

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:640px;">
    <h1 style="color:var(--gold);margin-bottom:8px;text-align:center;" data-i18n="contact-title">
      <span class="lang-jp">お問い合わせ</span>
      <span class="lang-en">Contact Us</span>
    </h1>
    <p style="color:var(--text-muted);margin-bottom:12px;text-align:center;" data-i18n="contact-sub">
      <span class="lang-jp">お問い合わせ、デモ口座のリクエスト、物々交換の提案など、お気軽にどうぞ。</span>
      <span class="lang-en">Feel free to reach out with inquiries, demo account requests, or barter trade proposals.</span>
    </p>

    <div class="email-card">
      <div class="email-icon">📧</div>
      <a href="mailto:william.classic@gmail.com" class="email-addr">william.classic@gmail.com</a>
      <p class="email-note" data-i18n="contact-note">
        <span class="lang-jp">※お返事までに1-2営業日いただく場合がございます。</span>
        <span class="lang-en">* Please allow 1-2 business days for a response.</span>
      </p>
    </div>

    <div class="alt-links">
      <p style="color:var(--text-muted);font-size:0.85rem;">
        <span data-i18n="contact-alt">
          <span class="lang-jp">こちらからもお問い合わせいただけます</span>
          <span class="lang-en">You can also reach us through</span>
        </span>：
      </p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:12px;">
        <a href={siteBase + '/demo/'} class="btn btn-gold" data-i18n="cta-demo">
          <span class="lang-jp">デモを申し込む</span>
          <span class="lang-en">Apply for Demo</span>
        </a>
        <a href={siteBase + '/faq/'} class="btn btn-outline" data-i18n="cta-faq">
          <span class="lang-jp">FAQを見る</span>
          <span class="lang-en">View FAQ</span>
        </a>
      </div>
    </div>
  </div>

  <style>
    .email-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px 24px;
      text-align: center;
      margin-bottom: 24px;
    }
    .email-icon { font-size: 2.5rem; margin-bottom: 16px; }
    .email-addr {
      display: block;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--gold);
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 8px;
      border: 1px dashed var(--gold-dark);
      background: rgba(212,175,55,0.06);
      transition: var(--transition);
      word-break: break-all;
    }
    .email-addr:hover {
      background: rgba(212,175,55,0.12);
      border-color: var(--gold);
    }
    .email-note {
      margin-top: 16px;
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .alt-links {
      text-align: center;
      padding: 20px;
      background: var(--bg-card);
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
  </style>
</BaseLayout>
