---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteBase = '/fusiongold-ea-site';
---

<BaseLayout title="ライブ取引の閲覧 | FusionGold M5" description="FusionGold M5 のリアルタイム取引を7日間無料で閲覧いただけます。">

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:640px;">

    <div style="text-align:center;margin-bottom:32px;">
      <h1 style="color:var(--gold);margin-bottom:8px;">
        <span class="lang-jp">ライブ取引を閲覧する</span>
        <span class="lang-en">Watch Live Trading</span>
      </h1>
      <p style="color:var(--text-muted);margin-bottom:4px;">
        <span class="lang-jp">実際の取引口座を7日間、リアルタイムでご覧いただけます。</span>
        <span class="lang-en">Watch our real trading account in real time for 7 days.</span>
      </p>
      <p style="color:var(--text-muted);font-size:0.85rem;">
        <span class="lang-jp">期間: 7日間 · IC Markets リアル口座 · MT5</span>
        <span class="lang-en">Duration: 7 days · IC Markets Live Account · MT5</span>
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:32px;">
      <div class="perk-card">
        <div class="perk-icon">👁️</div>
        <div class="perk-title">
          <span class="lang-jp">リアルタイム</span>
          <span class="lang-en">Real Time</span>
        </div>
        <div class="perk-desc">
          <span class="lang-jp">取引が行われる瞬間をライブで確認。</span>
          <span class="lang-en">Watch every trade as it happens live.</span>
        </div>
      </div>
      <div class="perk-card">
        <div class="perk-icon">📊</div>
        <div class="perk-title">
          <span class="lang-jp">完全透明</span>
          <span class="lang-en">Full Transparency</span>
        </div>
        <div class="perk-desc">
          <span class="lang-jp">口座残高、損益、取引履歴をすべて公開。</span>
          <span class="lang-en">Balance, P&L, and trade history fully visible.</span>
        </div>
      </div>
      <div class="perk-card">
        <div class="perk-icon">🆓</div>
        <div class="perk-title">
          <span class="lang-jp">無料</span>
          <span class="lang-en">Free</span>
        </div>
        <div class="perk-desc">
          <span class="lang-jp">7日間無料。クレジットカード不要。</span>
          <span class="lang-en">7 days free. No credit card required.</span>
        </div>
      </div>
    </div>

    <div class="demo-form-card" style="text-align:center;">
      <h2 style="color:var(--gold);font-size:1.05rem;margin-bottom:20px;">
        <span class="lang-jp">閲覧用パスワードを請求する</span>
        <span class="lang-en">Request View-Only Password</span>
      </h2>
      <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:20px;">
        <span class="lang-jp">下記のメールアドレスに、お名前とライブ取引閲覧希望の旨をお送りください。<br>閲覧用パスワード（investor password）をお送りします。MT5で口座を追加してご覧ください。</span>
        <span class="lang-en">Send your name and a request to watch live trading to the email below.<br>You will receive an investor (read-only) password. Add the account in MT5 to watch.</span>
      </p>
      <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:16px;margin-bottom:16px;text-align:center;">
        <div style="font-size:0.65rem;color:rgba(255,255,255,.35);margin-bottom:2px;">server</div>
        <div style="font-size:0.9rem;font-weight:600;color:var(--gold);margin-bottom:8px;">ICMarketsSC-Demo</div>
        <div style="font-size:0.65rem;color:rgba(255,255,255,.35);margin-bottom:2px;">account</div>
        <div style="font-size:1.2rem;font-weight:800;color:var(--gold);letter-spacing:2px;">52933861</div>
      </div>
      <a href="mailto:william.classic@gmail.com?subject=ライブ取引閲覧リクエスト&body=お名前：%0Aメールアドレス：" class="email-btn">
        📧 william.classic@gmail.com
      </a>
    </div>

    <div style="margin-top:32px;padding:20px;border-radius:var(--radius);background:rgba(212,175,55,0.06);border:1px dashed var(--gold-dark);text-align:center;">
      <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:4px;">
        <span class="lang-jp">すでにFusionGold M5についてご質問がありますか？</span>
        <span class="lang-en">Already have questions about FusionGold M5?</span>
      </p>
      <a href={siteBase + '/faq/'} style="color:var(--gold);">
        <span class="lang-jp">よくある質問を見る →</span>
        <span class="lang-en">View FAQ →</span>
      </a>
    </div>
  </div>

  <style>
    .perk-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 20px; text-align: center;
      transition: var(--transition);
    }
    .perk-card:hover { border-color: var(--gold-dark); }
    .perk-icon { font-size: 1.5rem; margin-bottom: 8px; }
    .perk-title { font-size: 0.9rem; color: var(--gold); font-weight: 600; margin-bottom: 6px; }
    .perk-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
    .demo-form-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px;
    }
    .email-btn {
      display: inline-block;
      padding: 14px 28px;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--gold);
      background: rgba(212,175,55,0.06);
      border: 1px dashed var(--gold-dark);
      border-radius: 10px;
      text-decoration: none;
      transition: var(--transition);
    }
    .email-btn:hover {
      background: rgba(212,175,55,0.12);
      border-color: var(--gold);
    }
  </style>
</BaseLayout>
