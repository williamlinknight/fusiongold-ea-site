---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteBase = '/fusiongold-ea-site';
const monthlyData = [
  { month: '2026/06', profit: 754.21, trades: 118, winRate: 75.42, avgWin: 17.88, avgLoss: -12.45, pf: 1.58, dd: 6.12 },
  { month: '2026/07', profit: 158.35, trades: 27, winRate: 70.37, avgWin: 16.22, avgLoss: -11.80, pf: 1.41, dd: 8.61 }
];
const weekdayData = [
  { day: '<span class="lang-jp">月曜日</span><span class="lang-en">Monday</span>', trades: 31, winRate: 77.42 },
  { day: '<span class="lang-jp">火曜日</span><span class="lang-en">Tuesday</span>', trades: 28, winRate: 75.00 },
  { day: '<span class="lang-jp">水曜日</span><span class="lang-en">Wednesday</span>', trades: 25, winRate: 72.00 },
  { day: '<span class="lang-jp">木曜日</span><span class="lang-en">Thursday</span>', trades: 30, winRate: 73.33 },
  { day: '<span class="lang-jp">金曜日</span><span class="lang-en">Friday</span>', trades: 31, winRate: 74.19 }
];
const hourlyData = [
  { hour: '21:00-22:00', trades: 42, winRate: 78.57 },
  { hour: '22:00-23:00', trades: 55, winRate: 76.36 },
  { hour: '23:00-24:00', trades: 38, winRate: 71.05 },
  { hour: '00:00-01:00', trades: 10, winRate: 60.00 }
];
const monthlyChart = [
  { label: '<span class="lang-jp">6月第1週</span><span class="lang-en">Jun Wk1</span>', equity: 1000 },
  { label: '<span class="lang-jp">6月第2週</span><span class="lang-en">Jun Wk2</span>', equity: 1120 },
  { label: '<span class="lang-jp">6月第3週</span><span class="lang-en">Jun Wk3</span>', equity: 1255 },
  { label: '<span class="lang-jp">6月第4週</span><span class="lang-en">Jun Wk4</span>', equity: 1460 },
  { label: '<span class="lang-jp">7月第1週</span><span class="lang-en">Jul Wk1</span>', equity: 1690 },
  { label: '<span class="lang-jp">7月第2週</span><span class="lang-en">Jul Wk2</span>', equity: 1912 }
];
---

<BaseLayout
  title='<span class="lang-jp">バックテスト詳細レポート | FusionGold M5</span><span class="lang-en">Backtest Detailed Report | FusionGold M5</span>'
  description='<span class="lang-jp">FusionGold M5 のバックテスト結果を詳細に分析。月次損益、ドローダウン、曜日別・時間帯別パフォーマンス。</span><span class="lang-en">Detailed analysis of FusionGold M5 backtest results. Monthly P&L, drawdown, performance by weekday and time zone.</span>'
>

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:800px;">
    <h1 style="color:var(--gold);margin-bottom:8px;">
      <span class="lang-jp">バックテスト詳細レポート</span>
      <span class="lang-en">Backtest Detailed Report</span>
    </h1>
    <p style="color:var(--text-muted);margin-bottom:4px;">
      <span class="lang-jp">検証期間: 2026年6月1日 〜 7月2日 · XAUUSD M1 · IC Markets Raw Spread</span>
      <span class="lang-en">Test Period: Jun 1 – Jul 2, 2026 · XAUUSD M1 · IC Markets Raw Spread</span>
    </p>
    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:32px;">
      <span class="lang-jp">※過去の結果は将来の成果を保証するものではありません。</span>
      <span class="lang-en">※ Past results do not guarantee future performance.</span>
    </p>

    <!-- ═══ <span class="lang-jp">サマリー</span><span class="lang-en">Summary</span> ═══ -->
    <div class="summary-grid">
      <div class="summary-card"><span class="s-label"><span class="lang-jp">総取引数</span><span class="lang-en">Total Trades</span></span><span class="s-value">145</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></span><span class="s-value highlight">74.48%</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">純利益</span><span class="lang-en">Net Profit</span></span><span class="s-value highlight">+$912.56</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">プロフィットファクター</span><span class="lang-en">Profit Factor</span></span><span class="s-value">1.54</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">最大ドローダウン</span><span class="lang-en">Max Drawdown</span></span><span class="s-value">8.61%</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">平均保有時間</span><span class="lang-en">Avg. Hold Time</span></span><span class="s-value">7min 55s</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">総利益</span><span class="lang-en">Gross Profit</span></span><span class="s-value">+$2,847.30</span></div>
      <div class="summary-card"><span class="s-label"><span class="lang-jp">総損失</span><span class="lang-en">Gross Loss</span></span><span class="s-value" style="color:var(--accent-red);">-$1,934.74</span></div>
    </div>

    <!-- ═══ <span class="lang-jp">エクイティカーブ</span><span class="lang-en">Equity Curve</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">エクイティカーブ</span><span class="lang-en">Equity Curve</span></h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:16px;">
        <span class="lang-jp">開始残高 $1,000 → 終了残高 $1,912.56（+91.25%）</span>
        <span class="lang-en">Starting Balance $1,000 → Ending Balance $1,912.56 (+91.25%)</span>
      </p>
      <div class="chart-container">
        <canvas id="equityChart"></canvas>
      </div>
    </div>

    <!-- ═══ <span class="lang-jp">月次パフォーマンス</span><span class="lang-en">Monthly Performance</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">月次パフォーマンス</span><span class="lang-en">Monthly Performance</span></h2>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr>
            <th><span class="lang-jp">月</span><span class="lang-en">Month</span></th>
            <th><span class="lang-jp">損益</span><span class="lang-en">P&L</span></th>
            <th><span class="lang-jp">取引数</span><span class="lang-en">Trades</span></th>
            <th><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></th>
            <th><span class="lang-jp">平均勝ち</span><span class="lang-en">Avg Win</span></th>
            <th><span class="lang-jp">平均負け</span><span class="lang-en">Avg Loss</span></th>
            <th>PF</th>
            <th><span class="lang-jp">最大DD</span><span class="lang-en">Max DD</span></th>
          </tr></thead>
          <tbody>
            {monthlyData.map(m => (
            <tr>
              <td>{m.month}</td>
              <td class="highlight">+${m.profit.toFixed(2)}</td>
              <td>{m.trades}</td>
              <td>{m.winRate}%</td>
              <td>+${m.avgWin.toFixed(2)}</td>
              <td style="color:var(--accent-red);">-${Math.abs(m.avgLoss).toFixed(2)}</td>
              <td>{m.pf}</td>
              <td>{m.dd}%</td>
            </tr>
            ))}
            <tr class="total-row">
              <td><strong><span class="lang-jp">トータル</span><span class="lang-en">Total</span></strong></td>
              <td class="highlight"><strong>+$912.56</strong></td>
              <td><strong>145</strong></td>
              <td><strong>74.48%</strong></td>
              <td><strong>+$17.60</strong></td>
              <td style="color:var(--accent-red);"><strong>-$12.30</strong></td>
              <td><strong>1.54</strong></td>
              <td><strong>8.61%</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══ <span class="lang-jp">売買方向別内訳</span><span class="lang-en">Direction Breakdown</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">売買方向別内訳</span><span class="lang-en">Buy/Sell Breakdown</span></h2>
      <div class="direction-grid">
        <div class="direction-card sell">
          <div class="dir-icon">SELL</div>
          <div class="dir-stats">
            <div><span class="dir-label"><span class="lang-jp">取引数</span><span class="lang-en">Trades</span></span><span>116</span></div>
            <div><span class="dir-label"><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></span><span class="highlight">79.31%</span></div>
            <div><span class="dir-label"><span class="lang-jp">純利益</span><span class="lang-en">Net Profit</span></span><span class="highlight">+$784.20</span></div>
          </div>
        </div>
        <div class="direction-card buy">
          <div class="dir-icon">BUY</div>
          <div class="dir-stats">
            <div><span class="dir-label"><span class="lang-jp">取引数</span><span class="lang-en">Trades</span></span><span>29</span></div>
            <div><span class="dir-label"><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></span><span class="highlight">55.17%</span></div>
            <div><span class="dir-label"><span class="lang-jp">純利益</span><span class="lang-en">Net Profit</span></span><span class="highlight">+$128.36</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ <span class="lang-jp">曜日別パフォーマンス</span><span class="lang-en">Weekday Performance</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">曜日別パフォーマンス</span><span class="lang-en">Weekday Performance</span></h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px;">
        <span class="lang-jp">ロンドン/NYオーバーラップ帯の流動性が高い月〜金曜に集中。</span>
        <span class="lang-en">Concentrated Mon–Fri during high-liquidity London/NY overlap.</span>
      </p>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr>
            <th><span class="lang-jp">曜日</span><span class="lang-en">Weekday</span></th>
            <th><span class="lang-jp">取引数</span><span class="lang-en">Trades</span></th>
            <th><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></th>
          </tr></thead>
          <tbody>
            {weekdayData.map(d => (
            <tr>
              <td>{d.day}</td>
              <td>{d.trades}</td>
              <td><div class="winbar"><span class="winbar-fill" style="width:{d.winRate}%">{d.winRate}%</span></div></td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══ <span class="lang-jp">時間帯別パフォーマンス</span><span class="lang-en">Hourly Performance</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">時間帯別パフォーマンス</span><span class="lang-en">Hourly Performance</span></h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px;">
        <span class="lang-jp">日本時間21:00〜24:00（ロンドン/ニューヨークオーバーラップ）に集中。</span>
        <span class="lang-en">Concentrated 21:00–24:00 JST (London/New York overlap).</span>
      </p>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr>
            <th><span class="lang-jp">時間帯（BJT）</span><span class="lang-en">Time (BJT)</span></th>
            <th><span class="lang-jp">取引数</span><span class="lang-en">Trades</span></th>
            <th><span class="lang-jp">勝率</span><span class="lang-en">Win Rate</span></th>
          </tr></thead>
          <tbody>
            {hourlyData.map(d => (
            <tr>
              <td>{d.hour}</td>
              <td>{d.trades}</td>
              <td><div class="winbar"><span class="winbar-fill" style="width:{d.winRate}%">{d.winRate}%</span></div></td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══ <span class="lang-jp">ドローダウン分析</span><span class="lang-en">Drawdown Analysis</span> ═══ -->
    <div class="section-card">
      <h2><span class="lang-jp">ドローダウン分析</span><span class="lang-en">Drawdown Analysis</span></h2>
      <div class="dd-grid">
        <div class="dd-card">
          <div class="dd-title"><span class="lang-jp">最大ドローダウン</span><span class="lang-en">Max Drawdown</span></div>
          <div class="dd-value">8.61%</div>
          <div class="dd-desc"><span class="lang-jp">絶対額: $164.67</span><span class="lang-en">Absolute: $164.67</span></div>
        </div>
        <div class="dd-card">
          <div class="dd-title"><span class="lang-jp">最大ドローダウン期間</span><span class="lang-en">Max DD Period</span></div>
          <div class="dd-value"><span class="lang-jp">3日</span><span class="lang-en">3 Days</span></div>
          <div class="dd-desc">2026/06/17 – 2026/06/19</div>
        </div>
        <div class="dd-card">
          <div class="dd-title"><span class="lang-jp">平均ドローダウン</span><span class="lang-en">Avg Drawdown</span></div>
          <div class="dd-value">2.34%</div>
          <div class="dd-desc"><span class="lang-jp">回復までの平均: 1.2日</span><span class="lang-en">Avg Recovery: 1.2 Days</span></div>
        </div>
        <div class="dd-card">
          <div class="dd-title"><span class="lang-jp">最大連敗</span><span class="lang-en">Max Consec. Losses</span></div>
          <div class="dd-value"><span class="lang-jp">3連敗</span><span class="lang-en">3 Losses</span></div>
          <div class="dd-desc"><span class="lang-jp">合計損失: -$152.30</span><span class="lang-en">Total Loss: -$152.30</span></div>
        </div>
      </div>
    </div>

    <div style="margin-top:32px;text-align:center;padding:24px;border-radius:var(--radius);background:var(--bg-card);border:1px solid var(--border);">
      <p style="color:var(--text-muted);margin-bottom:16px;">
        <span class="lang-jp">バックテストの結果にご満足いただけましたか？デモ口座で実際の動作をお試しください。</span>
        <span class="lang-en">Satisfied with the backtest results? Try it live on a demo account.</span>
      </p>
      <a href={siteBase + '/demo/'} class="btn btn-gold">
        <span class="lang-jp">デモを試す</span>
        <span class="lang-en">Try Demo</span>
      </a>
    </div>
  </div>

  <!-- Chart.js -->
  <script>
    (async function() {
      const canvas = document.getElementById('equityChart');
      if (!canvas) return;
      const { Chart, registerables } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
      Chart.register(...registerables);
      new Chart(canvas, {
        type: 'line',
        data: {
          labels: [
            '<span class="lang-jp">6月第1週</span><span class="lang-en">Jun Wk1</span>',
            '<span class="lang-jp">6月第2週</span><span class="lang-en">Jun Wk2</span>',
            '<span class="lang-jp">6月第3週</span><span class="lang-en">Jun Wk3</span>',
            '<span class="lang-jp">6月第4週</span><span class="lang-en">Jun Wk4</span>',
            '<span class="lang-jp">7月第1週</span><span class="lang-en">Jul Wk1</span>',
            '<span class="lang-jp">7月第2週</span><span class="lang-en">Jul Wk2</span>'
          ],
          datasets: [{
            label: '<span class="lang-jp">残高推移 ($)</span><span class="lang-en">Balance ($)</span>',
            data: [1000,1120,1255,1460,1690,1912],
            borderColor: '#D4AF37',
            backgroundColor: 'rgba(212,175,55,0.08)',
            fill: true,
            tension: 0.3,
            pointRadius: 4,
            pointBackgroundColor: '#D4AF37'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              labels: {
                color: '#ccc',
                font: { size: 12 }
              }
            }
          },
          scales: {
            x: {
              ticks: { color: '#888' },
              grid: { color: 'rgba(255,255,255,0.05)' }
            },
            y: {
              ticks: { color: '#888', callback: v => '$' + v },
              grid: { color: 'rgba(255,255,255,0.05)' }
            }
          }
        }
      });
    })();
  </script>

  <style>
    .summary-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:10px; margin-bottom:24px; }
    .summary-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:16px; text-align:center; }
    .s-label { display:block; font-size:0.7rem; color:var(--text-muted); margin-bottom:4px; }
    .s-value { display:block; font-size:1.15rem; font-weight:700; color:var(--text); }
    .s-value.highlight { color:var(--gold); }
    .section-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:24px; margin-bottom:20px; }
    .section-card h2 { color:var(--gold); font-size:1.05rem; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--border); }
    .chart-container { position:relative; height:260px; }
    .table-wrap { overflow-x:auto; }
    .data-table { width:100%; border-collapse:collapse; font-size:0.85rem; }
    .data-table th { color:var(--gold); font-weight:600; font-size:0.8rem; padding:8px 10px; text-align:center; border-bottom:2px solid var(--border); }
    .data-table td { padding:8px 10px; text-align:center; color:var(--text-muted); border-bottom:1px solid var(--border); }
    .data-table .highlight { color:var(--gold); font-weight:600; }
    .data-table .total-row td { border-top:2px solid var(--gold); color:var(--text); }
    .winbar { background:rgba(255,255,255,0.06); border-radius:4px; height:20px; overflow:hidden; min-width:80px; }
    .winbar-fill { display:block; height:100%; background:linear-gradient(90deg,rgba(212,175,55,0.3),rgba(212,175,55,0.6)); border-radius:4px; font-size:0.7rem; line-height:20px; padding:0 6px; color:#fff; text-align:right; }
    .direction-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .direction-card { padding:16px; border-radius:var(--radius); border:1px solid var(--border); }
    .direction-card.sell { background:rgba(231,76,60,0.06); }
    .direction-card.buy { background:rgba(46,204,113,0.06); }
    .dir-icon { font-size:1.1rem; font-weight:800; margin-bottom:8px; }
    .direction-card.sell .dir-icon { color:var(--accent-red); }
    .direction-card.buy .dir-icon { color:var(--accent-green); }
    .dir-stats { display:flex; flex-direction:column; gap:4px; font-size:0.85rem; }
    .dir-stats div { display:flex; justify-content:space-between; }
    .dir-label { color:var(--text-muted); }
    .dd-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:10px; }
    .dd-card { padding:14px; border-radius:8px; background:var(--bg); border:1px solid var(--border); text-align:center; }
    .dd-title { font-size:0.75rem; color:var(--text-muted); margin-bottom:4px; }
    .dd-value { font-size:1.1rem; font-weight:700; color:var(--gold); }
    .dd-desc { font-size:0.75rem; color:var(--text-muted); margin-top:2px; }
    @media (max-width:600px) {
      .direction-grid { grid-template-columns:1fr; }
      .summary-grid { grid-template-columns:repeat(2,1fr); }
    }
  </style>
</BaseLayout>
