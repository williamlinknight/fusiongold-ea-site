---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const dataPath = path.resolve(process.cwd(), 'public/data/ea-status.json');
const raw = fs.readFileSync(dataPath, 'utf-8');
const data = JSON.parse(raw);
const siteBase = '/fusiongold-ea-site';
const { account, session, market, signal, risk, lastTrades, tradeHistory } = data;
---

<BaseLayout title="ライブパフォーマンス | FusionGold M5" description="FusionGold M5 のリアルタイムパフォーマンス。口座残高、エクイティ、取引履歴。">

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:800px;">
    <h1 style="color:var(--gold);margin-bottom:4px;">ライブパフォーマンス</h1>
    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:32px;">最終更新: {data.updated} · IC Markets Raw Spread · リアル口座</p>

    <!-- ═══ アカウントサマリー ═══ -->
    <div class="summary-grid">
      <div class="sm-card">
        <div class="sm-label">口座残高</div>
        <div class="sm-value">${account.balance.toFixed(2)}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label">エクイティ</div>
        <div class="sm-value">${account.equity.toFixed(2)}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label">本日P&L</div>
        <div class="sm-value" style="color:{account.dayPnL >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
          {account.dayPnL >= 0 ? '+' : ''}{account.dayPnL.toFixed(2)} ({account.dayPnLPercent}%)
        </div>
      </div>
      <div class="sm-card">
        <div class="sm-label">ポジション数</div>
        <div class="sm-value">{account.positions} / {account.maxPositions}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label">セッション状態</div>
        <div class="sm-value">
          <span class={`status-badge ${session.status === 'RUNNING' ? 'green' : 'amber'}`}>{session.status}</span>
        </div>
      </div>
      <div class="sm-card">
        <div class="sm-label">クールダウン</div>
        <div class="sm-value">{session.cooldown > 0 ? session.cooldown + 's' : 'なし'}</div>
      </div>
    </div>

    <!-- ═══ エクイティカーブ ═══ -->
    <div class="section-card">
      <h2>📈 エクイティカーブ（フォワードテスト）</h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:16px;">直近の日次損益を累積表示。開始からのパフォーマンス推移。</p>
      <div class="chart-container">
        <canvas id="equityChart"></canvas>
      </div>
      <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;">
        <div class="stat-chip"><span class="chip-label">期間</span><span>{tradeHistory.length}日</span></div>
        <div class="stat-chip"><span class="chip-label">総損益</span><span style="color:var(--accent-green);">{(() => { const t = tradeHistory.reduce((s, d) => s + d.pnl, 0); return (t >= 0 ? '+' : '') + '$' + t.toFixed(2); })()}</span></div>
        <div class="stat-chip"><span class="chip-label">取引日勝率</span><span>{(() => { const a = tradeHistory.filter(d => d.trades > 0); const w = a.filter(d => d.pnl > 0).length; return a.length > 0 ? (w / a.length * 100).toFixed(1) + '%' : '0%'; })()}</span></div>
      </div>
    </div>

    <!-- ═══ シグナル状態 ═══ -->
    <div class="section-card">
      <h2>🎯 現在のシグナル状態</h2>
      <div class="signal-grid">
        <div class="sig-item">
          <span class="sig-label">ADX</span>
          <span class="sig-val">{market.adx}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">H4買い許可</span>
          <span class="sig-val sig-bool {signal.h4Buy === 'Y' ? 'on' : 'off'}">{signal.h4Buy}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">H4売り許可</span>
          <span class="sig-val sig-bool {signal.h4Sell === 'Y' ? 'on' : 'off'}">{signal.h4Sell}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">買いシグナル</span>
          <span class="sig-val sig-bool {signal.canBuy === 'Y' ? 'on' : 'off'}">{signal.canBuy}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">売りシグナル</span>
          <span class="sig-val sig-bool {signal.canSell === 'Y' ? 'on' : 'off'}">{signal.canSell}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">必要スコア</span>
          <span class="sig-val">{signal.need}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">スプレッド</span>
          <span class="sig-val">{market.spread}</span>
        </div>
        <div class="sig-item">
          <span class="sig-label">リスク制限</span>
          <span class="sig-val sig-bool {risk.dailyLossLimit ? 'on' : 'off'}">{risk.dailyLossLimit ? '発動中' : '正常'}</span>
        </div>
      </div>
    </div>

    <!-- ═══ 直近トレード ═══ -->
    <div class="section-card">
      <h2>⚡ 直近取引</h2>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr><th>時間</th><th>方向</th><th>ロット</th><th>P&L</th></tr></thead>
          <tbody>
            {lastTrades.map(t => (
            <tr>
              <td>{t.time}</td>
              <td><span class={`dir-badge ${t.type === 'SELL' ? 'sell' : 'buy'}`}>{t.type}</span></td>
              <td>{t.lots.toFixed(2)}</td>
              <td style="font-weight:600;color:{t.pnl >= 0 ? (t.result === 'WIN' ? 'var(--accent-green)' : 'var(--text-muted)') : 'var(--accent-red)'}">
                {t.pnl >= 0 ? '+' : ''}{t.pnl.toFixed(2)}
              </td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div style="margin-top:24px;text-align:center;padding:20px;background:var(--bg-card);border-radius:var(--radius);border:1px solid var(--border);">
      <p style="color:var(--text-muted);margin-bottom:12px;font-size:0.85rem;">バックテスト詳細はこちら</p>
      <a href={siteBase + '/backtest/'} class="btn btn-gold">バックテストレポートを見る</a>
    </div>
  </div>

  <!-- Chart.js -->
  <script is:inline>
    window.__tradeHistory = JSON.parse(decodeURIComponent('{encodeURIComponent(JSON.stringify(tradeHistory))}'));
    window.__startBalance = {data.startBalance || 5075.28};
  </script>
  <script>
    (async function() {
      const canvas = document.getElementById('equityChart');
      if (!canvas) return;
      const { Chart, registerables } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
      Chart.register(...registerables);

      const history = window.__tradeHistory;
      let cum = window.__startBalance || 5075.28;
      const labels = [];
      const equityData = [];
      // Reverse to show chronological order
      const reversed = [...history].reverse();
      for (const d of reversed) {
        cum += d.pnl;
        labels.push(d.date.slice(5));
        equityData.push(cum);
      }

      new Chart(canvas, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'エクイティ ($)',
            data: equityData,
            borderColor: '#D4AF37',
            backgroundColor: 'rgba(212,175,55,0.08)',
            fill: true,
            tension: 0.3,
            pointRadius: 3,
            pointBackgroundColor: '#D4AF37'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { labels: { color: '#ccc', font: { size: 12 } } } },
          scales: {
            x: { ticks: { color: '#888', maxTicksLimit: 7 }, grid: { color: 'rgba(255,255,255,0.05)' } },
            y: { ticks: { color: '#888', callback: v => '$' + v.toFixed(0) }, grid: { color: 'rgba(255,255,255,0.05)' } }
          }
        }
      });
    })();
  </script>

  <style>
    .summary-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:10px; margin-bottom:20px; }
    .sm-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:14px; text-align:center; }
    .sm-label { font-size:0.7rem; color:var(--text-muted); margin-bottom:4px; }
    .sm-value { font-size:1.05rem; font-weight:700; color:var(--text); }
    .status-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:0.75rem; font-weight:600; }
    .status-badge.green { background:rgba(46,204,113,0.15); color:var(--accent-green); }
    .status-badge.amber { background:rgba(241,196,15,0.15); color:#f1c40f; }
    .section-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:24px; margin-bottom:20px; }
    .section-card h2 { color:var(--gold); font-size:1.05rem; margin-bottom:8px; }
    .chart-container { position:relative; height:240px; }
    .table-wrap { overflow-x:auto; }
    .data-table { width:100%; border-collapse:collapse; font-size:0.85rem; }
    .data-table th { color:var(--gold); font-weight:600; font-size:0.8rem; padding:8px 10px; text-align:center; border-bottom:2px solid var(--border); }
    .data-table td { padding:8px 10px; text-align:center; color:var(--text-muted); border-bottom:1px solid var(--border); }
    .dir-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:0.75rem; font-weight:700; }
    .dir-badge.sell { background:rgba(231,76,60,0.12); color:var(--accent-red); }
    .dir-badge.buy { background:rgba(46,204,113,0.12); color:var(--accent-green); }
    .signal-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:8px; }
    .sig-item { padding:10px; border-radius:6px; background:var(--bg); text-align:center; }
    .sig-label { display:block; font-size:0.7rem; color:var(--text-muted); margin-bottom:3px; }
    .sig-val { font-size:1rem; font-weight:700; color:var(--text); }
    .sig-val.sig-bool.on { color:var(--accent-green); }
    .sig-val.sig-bool.off { color:var(--accent-red); }
    .stat-chip { display:flex; gap:6px; align-items:center; padding:6px 14px; border-radius:20px; background:var(--bg); border:1px solid var(--border); font-size:0.8rem; }
    .chip-label { color:var(--text-muted); }
    @media (max-width:600px) { .summary-grid { grid-template-columns:repeat(2,1fr); } }
  </style>
</BaseLayout>
