---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const dataPath = path.resolve(process.cwd(), 'public/data/ea-status.json');
const raw = fs.readFileSync(dataPath, 'utf-8');
const data = JSON.parse(raw);
const siteBase = '/fusiongold-ea-site';
const { account, session, lastTrades, tradeHistory } = data;

// Compute equity curve data (server-side)
const reversed = [...tradeHistory].reverse();
let cum = data.startBalance || 5075.28;
const equityPoints = [];
for (const d of reversed) {
  cum += d.pnl;
  equityPoints.push({ label: d.date.slice(5), value: cum });
}
const totalPnl = tradeHistory.reduce((s, d) => s + d.pnl, 0);
const tradingDays = tradeHistory.filter(d => d.trades > 0);
const wrDays = tradingDays.length > 0
  ? (tradingDays.filter(d => d.pnl > 0).length / tradingDays.length * 100).toFixed(1)
  : '0';

// SVG chart dimensions
const SVG_W = 600, SVG_H = 220;
const PAD = { top: 20, right: 20, bottom: 30, left: 55 };
const chartW = SVG_W - PAD.left - PAD.right;
const chartH = SVG_H - PAD.top - PAD.bottom;

const vals = equityPoints.map(p => p.value);
const minVal = Math.min(...vals);
const maxVal = Math.max(...vals);
const range = maxVal - minVal || 1;
const padRange = range * 0.1;

function x(i) { return PAD.left + (i / (equityPoints.length - 1 || 1)) * chartW; }
function y(v) { return PAD.top + chartH - ((v - (minVal - padRange)) / (range + 2 * padRange)) * chartH; }

const pathD = equityPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)},${y(p.value).toFixed(1)}`).join(' ');

// Y-axis ticks
const yTicks = 5;
const yStep = (range + 2 * padRange) / yTicks;
const yLabels = [];
for (let i = 0; i <= yTicks; i++) {
  const v = (minVal - padRange) + i * yStep;
  yLabels.push(v);
}

// X-axis ticks (show alternating to avoid crowding)
const xTicks = equityPoints.filter((_, i) => i === 0 || i === equityPoints.length - 1 || i % 2 === 0);
---

<BaseLayout title="Live Performance | FusionGold M5" description="FusionGold M5 real-time performance — balance, equity, trade history.">

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:800px;">
    <h1 style="color:var(--gold);margin-bottom:4px;" data-i18n="live-title">ライブパフォーマンス</h1>
    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:32px;"><span data-i18n="live-updated">最終更新</span>: {data.updated} · IC Markets Raw Spread · <span data-i18n="live-liveaccount">リアル口座</span></p>

    <!-- ═══ Account Summary ═══ -->
    <div class="summary-grid">
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-balance">口座残高</div>
        <div class="sm-value">${account.balance.toFixed(2)}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-equity">有効証拠金</div>
        <div class="sm-value">${account.equity.toFixed(2)}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-daypnl">本日P&L</div>
        <div class="sm-value" style="color:{account.dayPnL >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
          {account.dayPnL >= 0 ? '+' : ''}{account.dayPnL.toFixed(2)} ({account.dayPnLPercent}%)
        </div>
      </div>
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-positions">ポジション</div>
        <div class="sm-value">{account.positions} / {account.maxPositions}</div>
      </div>
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-status">ステータス</div>
        <div class="sm-value">
          <span class={`status-badge ${session.status === 'RUNNING' ? 'green' : 'amber'}`}>{session.status}</span>
        </div>
      </div>
      <div class="sm-card">
        <div class="sm-label" data-i18n="live-cooldown">クールダウン</div>
        <div class="sm-value" id="cooldown-value">{session.cooldown > 0 ? session.cooldown + 's' : ''}</div>
      </div>
    </div>

    <!-- ═══ Equity Curve (Server-Side SVG) ═══ -->
    <div class="section-card">
      <h2 data-i18n="live-equity-title">📈 エクイティカーブ（フォワードテスト）</h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:16px;" data-i18n="live-equity-sub">直近の日次損益を累積表示。開始からのパフォーマンス推移。</p>
      <div class="chart-container">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} style="width:100%;height:100%;" preserveAspectRatio="xMidYMid meet">
          <!-- Grid lines -->
          {yLabels.map(v => (
            <line x1={PAD.left} y1={y(v)} x2={SVG_W - PAD.right} y2={y(v)} stroke="rgba(255,255,255,0.06)" stroke-width="1" />
          ))}
          <!-- Y-axis labels -->
          {yLabels.map(v => (
            <text x={PAD.left - 8} y={y(v) + 4} text-anchor="end" fill="#8A8A9A" font-size="11">${Math.round(v)}</text>
          ))}
          <!-- X-axis labels -->
          {xTicks.map((p, i) => (
            <text x={x(equityPoints.indexOf(p))} y={SVG_H - 6} text-anchor="middle" fill="#8A8A9A" font-size="10">{p.label}</text>
          ))}
          <!-- Area fill -->
          <path d={`${pathD} L${x(equityPoints.length - 1)},${PAD.top + chartH} L${x(0)},${PAD.top + chartH} Z`} fill="rgba(212,175,55,0.08)" />
          <!-- Line -->
          <path d={pathD} fill="none" stroke="#D4AF37" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
          <!-- Data points -->
          {equityPoints.map((p, i) => (
            <circle cx={x(i)} cy={y(p.value)} r="3" fill="#D4AF37" />
          ))}
        </svg>
      </div>
      <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;">
        <div class="stat-chip"><span class="chip-label" data-i18n="live-period">期間</span><span>{tradeHistory.length}<span data-i18n="live-period-unit">日</span></span></div>
        <div class="stat-chip"><span class="chip-label" data-i18n="live-totalpnl">総損益</span><span style="color:var(--accent-green);">{totalPnl >= 0 ? '+' : ''}${totalPnl.toFixed(2)}</span></div>
        <div class="stat-chip"><span class="chip-label" data-i18n="live-wr-days">取引日勝率</span><span>{wrDays}%</span></div>
      </div>
    </div>

    <!-- ═══ Recent Trades ═══ -->
    <div class="section-card">
      <h2 data-i18n="live-recent-title">⚡ 直近取引</h2>
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr><th data-i18n="live-time">時間</th><th data-i18n="live-dir">方向</th><th data-i18n="live-lot">ロット</th><th>P&amp;L</th></tr></thead>
          <tbody>
            {lastTrades.map(t => (
            <tr>
              <td>{t.time}</td>
              <td><span class={`dir-badge ${t.type === 'SELL' ? 'sell' : 'buy'}`}>{t.type}</span></td>
              <td>{t.lots.toFixed(2)}</td>
              <td style="font-weight:600;color:{t.pnl >= 0 ? (t.result === 'WIN' ? 'var(--accent-green)' : 'var(--text-muted)') : 'var(--accent-red)'}">
                {t.pnl >= 0 ? '+' : ''}{t.pnl.toFixed(2)}
              </td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div style="margin-top:24px;text-align:center;padding:20px;background:var(--bg-card);border-radius:var(--radius);border:1px solid var(--border);">
      <p style="color:var(--text-muted);margin-bottom:12px;font-size:0.85rem;" data-i18n="live-view-bt">バックテスト詳細はこちら</p>
      <a href={siteBase + '/backtest/'} class="btn btn-gold" data-i18n="live-bt-btn">バックテストレポートを見る</a>
    </div>
  </div>

  <!-- i18n dynamic text handler -->
  <script is:inline>
    window.__cooldown = {session.cooldown};
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      function waitForLang() {
        return new Promise(resolve => {
          if (window.LANG) return resolve();
          const check = setInterval(() => {
            if (window.LANG) { clearInterval(check); resolve(); }
          }, 10);
        });
      }
      waitForLang().then(() => {
        const origSet = LANG.set;
        LANG.set = function(lang) {
          origSet(lang);
          const cd = document.getElementById('cooldown-value');
          if (cd) cd.textContent = window.__cooldown > 0 ? window.__cooldown + 's' : (lang === 'JP' ? 'なし' : 'None');
        };
      });
    });
  </script>

  <style>
    .summary-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:10px; margin-bottom:20px; }
    .sm-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:14px; text-align:center; }
    .sm-label { font-size:0.7rem; color:var(--text-muted); margin-bottom:4px; }
    .sm-value { font-size:1.05rem; font-weight:700; color:var(--text); }
    .status-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:0.75rem; font-weight:600; }
    .status-badge.green { background:rgba(46,204,113,0.15); color:var(--accent-green); }
    .status-badge.amber { background:rgba(241,196,15,0.15); color:#f1c40f; }
    .section-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:24px; margin-bottom:20px; }
    .section-card h2 { color:var(--gold); font-size:1.05rem; margin-bottom:8px; }
    .chart-container { position:relative; height:220px; width:100%; }
    .chart-container svg { display:block; }
    .table-wrap { overflow-x:auto; }
    .data-table { width:100%; border-collapse:collapse; font-size:0.85rem; }
    .data-table th { color:var(--gold); font-weight:600; font-size:0.8rem; padding:8px 10px; text-align:center; border-bottom:2px solid var(--border); }
    .data-table td { padding:8px 10px; text-align:center; color:var(--text-muted); border-bottom:1px solid var(--border); }
    .dir-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:0.75rem; font-weight:700; }
    .dir-badge.sell { background:rgba(231,76,60,0.12); color:var(--accent-red); }
    .dir-badge.buy { background:rgba(46,204,113,0.12); color:var(--accent-green); }
    .signal-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:8px; }
    .sig-item { padding:10px; border-radius:6px; background:var(--bg); text-align:center; }
    .sig-label { display:block; font-size:0.7rem; color:var(--text-muted); margin-bottom:3px; }
    .sig-val { font-size:1rem; font-weight:700; color:var(--text); }
    .sig-val.sig-bool.on { color:var(--accent-green); }
    .sig-val.sig-bool.off { color:var(--accent-red); }
    .stat-chip { display:flex; gap:6px; align-items:center; padding:6px 14px; border-radius:20px; background:var(--bg); border:1px solid var(--border); font-size:0.8rem; }
    .chip-label { color:var(--text-muted); }
    @media (max-width:600px) { .summary-grid { grid-template-columns:repeat(2,1fr); } }
  </style>
</BaseLayout>
