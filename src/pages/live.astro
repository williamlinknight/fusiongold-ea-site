---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs/promises';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
let statusData;
try {
  const raw = await fs.readFile('public/data/ea-status.json', 'utf-8');
  statusData = JSON.parse(raw);
} catch {
  statusData = null;
}
const d = statusData || {};
const acct = d.account || {};
const sess = d.session || {};
const mkt = d.market || {};
const sig = d.signal || {};
const risk = d.risk || {};
const history = d.tradeHistory || [];
const lastTrades = d.lastTrades || [];
---

<BaseLayout title="ライブパフォーマンス | FusionGold M5" description="FusionGold M5 のリアルタイム取引状況。残高、ポジション、P&L。">
  <div class="container" style="padding-top:40px;padding-bottom:60px;">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;margin-bottom:24px;">
      <h1 style="color:var(--gold);">ライブパフォーマンス</h1>
      <span style="font-size:0.8rem;color:var(--text-muted);">最終更新: {d.updated || '—'}</span>
    </div>

    <!-- 📊 アカウント Overview -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:24px;">
      <div class="stat-card">
        <div class="stat-label">残高</div>
        <div class="stat-value gold">${acct.balance?.toFixed(2) || '—'}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">有効証拠金</div>
        <div class="stat-value">${acct.equity?.toFixed(2) || '—'}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">本日P&L</div>
        <div class="stat-value" style="color:{acct.dayPnL >= 0 ? '#27ae60' : '#e74c3c'};">${(acct.dayPnL >= 0 ? '+' : '') + (acct.dayPnL?.toFixed(2) || '0.00')}</div>
        <div class="stat-sub" style="color:{acct.dayPnL >= 0 ? '#27ae60' : '#e74c3c'};">{acct.dayPnLPercent >= 0 ? '+' : ''}{(acct.dayPnLPercent || 0).toFixed(2)}%</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">ポジション</div>
        <div class="stat-value">{acct.positions || 0}/{acct.maxPositions || 4}</div>
      </div>
    </div>

    <!-- ⚡ EA ステータス -->
    <div style="background:var(--bg-card);border-radius:var(--radius);padding:24px;border:1px solid var(--border);margin-bottom:24px;">
      <h2 style="color:var(--gold);font-size:1.1rem;margin-bottom:16px;">⚡ EA ステータス</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;">
        <div><span class="tag-label">ステータス</span><span class="tag-value" style="color:{acct.status === 'RUNNING' ? '#27ae60' : '#e74c3c'};">{acct.status || '—'}</span></div>
        <div><span class="tag-label">セッション</span><span class="tag-value" style="color:{sess.status === 'OK' ? '#27ae60' : '#f39c12'};">{sess.status || '—'}</span></div>
        <div><span class="tag-label">ADX</span><span class="tag-value">{mkt.adx?.toFixed(1) || '—'}</span></div>
        <div><span class="tag-label">スプレッド</span><span class="tag-value">{mkt.spread || '—'}/{mkt.maxSpread || '—'}</span></div>
        <div><span class="tag-label">H4 Buy/Sell</span><span class="tag-value">{sig.h4Buy}/{sig.h4Sell}</span></div>
        <div><span class="tag-label">Buy/Sell</span><span class="tag-value">{sig.canBuy}/{sig.canSell}</span></div>
        <div><span class="tag-label">Bull/Bear</span><span class="tag-value">{sig.bull}/{sig.bear}</span></div>
        <div><span class="tag-label">クールダウン</span><span class="tag-value">{sess.cooldown || 0}s</span></div>
      </div>
    </div>

    <!-- ⚠️ リスクステータス -->
    {risk.consecutiveLossPause && (
    <div style="background:rgba(231,76,60,.1);border:1px solid #e74c3c;border-radius:var(--radius);padding:16px;margin-bottom:24px;">
      <strong style="color:#e74c3c;">⚠️ 連損フィルター作動中</strong> — 連続損失により60分停止中
    </div>
    )}
    {risk.dailyLossLimit && (
    <div style="background:rgba(231,76,60,.1);border:1px solid #e74c3c;border-radius:var(--radius);padding:16px;margin-bottom:24px;">
      <strong style="color:#e74c3c;">⚠️ 日損リミット到達</strong> — 本日の取引を停止しました
    </div>
    )}

    <!-- 📈 日次P&L履歴 -->
    <div style="background:var(--bg-card);border-radius:var(--radius);padding:24px;border:1px solid var(--border);margin-bottom:24px;">
      <h2 style="color:var(--gold);font-size:1.1rem;margin-bottom:16px;">📈 日次P&L履歴</h2>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th style="padding:8px 12px;text-align:left;color:var(--text-muted);font-weight:400;font-size:0.85rem;">日付</th>
            <th style="padding:8px 12px;text-align:right;color:var(--text-muted);font-weight:400;font-size:0.85rem;">P&L</th>
            <th style="padding:8px 12px;text-align:center;color:var(--text-muted);font-weight:400;font-size:0.85rem;">取引数</th>
            <th style="padding:8px 12px;text-align:center;color:var(--text-muted);font-weight:400;font-size:0.85rem;">勝率</th>
          </tr></thead>
          <tbody>
            {history.map(h => (
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:8px 12px;font-size:0.9rem;">{h.date}</td>
              <td style="padding:8px 12px;text-align:right;font-weight:600;color:{h.pnl >= 0 ? '#27ae60' : '#e74c3c'};">{(h.pnl >= 0 ? '+' : '') + h.pnl.toFixed(2)}</td>
              <td style="padding:8px 12px;text-align:center;">{h.trades}</td>
              <td style="padding:8px 12px;text-align:center;">{h.winRate > 0 ? h.winRate + '%' : '—'}</td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- 🎯 最新取引 -->
    <div style="background:var(--bg-card);border-radius:var(--radius);padding:24px;border:1px solid var(--border);">
      <h2 style="color:var(--gold);font-size:1.1rem;margin-bottom:16px;">🎯 最新取引</h2>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th style="padding:8px 12px;color:var(--text-muted);font-weight:400;font-size:0.85rem;">時間</th>
            <th style="padding:8px 12px;color:var(--text-muted);font-weight:400;font-size:0.85rem;">タイプ</th>
            <th style="padding:8px 12px;text-align:right;color:var(--text-muted);font-weight:400;font-size:0.85rem;">ロット</th>
            <th style="padding:8px 12px;text-align:right;color:var(--text-muted);font-weight:400;font-size:0.85rem;">P&L</th>
            <th style="padding:8px 12px;text-align:center;color:var(--text-muted);font-weight:400;font-size:0.85rem;">結果</th>
          </tr></thead>
          <tbody>
            {lastTrades.map(t => (
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:8px 12px;font-size:0.9rem;">{t.time}</td>
              <td style="padding:8px 12px;color:var(--gold);font-weight:600;">{t.type}</td>
              <td style="padding:8px 12px;text-align:right;">{t.lots.toFixed(2)}</td>
              <td style="padding:8px 12px;text-align:right;font-weight:600;color:{t.pnl >= 0 ? '#27ae60' : '#e74c3c'};">{(t.pnl >= 0 ? '+' : '') + t.pnl.toFixed(2)}</td>
              <td style="padding:8px 12px;text-align:center;">
                <span style="display:inline-block;padding:2px 10px;border-radius:10px;font-size:0.8rem;font-weight:600;
                  {t.result === 'WIN' ? 'background:rgba(39,174,96,.15);color:#27ae60;' : ''}
                  {t.result === 'LOSS' ? 'background:rgba(231,76,60,.15);color:#e74c3c;' : ''}
                  {t.result === 'OPEN' ? 'background:rgba(241,196,15,.15);color:#f1c40f;' : ''}
                ">{t.result}</span>
              </td>
            </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <style>
    .stat-card {
      background:var(--bg-card);
      border-radius:var(--radius);
      padding:20px;
      border:1px solid var(--border);
      text-align:center;
    }
    .stat-label {
      font-size:0.8rem;
      color:var(--text-muted);
      margin-bottom:4px;
    }
    .stat-value {
      font-size:1.4rem;
      font-weight:700;
      color:var(--text-heading);
    }
    .stat-value.gold { color:var(--gold); }
    .stat-sub { font-size:0.85rem; }
    .tag-label {
      display:block;
      font-size:0.75rem;
      color:var(--text-muted);
      margin-bottom:2px;
    }
    .tag-value {
      font-size:0.95rem;
      font-weight:600;
      color:var(--text-heading);
    }
  </style>
</BaseLayout>
