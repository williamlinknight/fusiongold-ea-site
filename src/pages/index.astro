---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const siteBase = '/fusiongold-ea-site';

// Load live data for the forward test section
let liveData = null;
try {
  const dp = path.resolve(process.cwd(), 'public/data/ea-status.json');
  liveData = JSON.parse(fs.readFileSync(dp, 'utf-8'));
} catch {}
const ld = liveData?.account || { balance: 4797, dayPnL: 0, dayPnLPercent: 0 };
const session = liveData?.session || { status: 'WAITING', cooldown: 0 };
const th = liveData?.tradeHistory || [];
const lastTrades = liveData?.lastTrades || [];
const totalPnl = th.reduce((s, d) => s + d.pnl, 0);

// Compute live stats from forward test data
const liveTrades = th.reduce((s, d) => s + d.trades, 0);
const liveWinDays = th.filter(d => d.pnl > 0).length;
const liveLossDays = th.filter(d => d.pnl < 0).length;
const liveWinDaysTotal = liveWinDays + liveLossDays;
const liveDayWr = liveWinDaysTotal > 0 ? (liveWinDays / liveWinDaysTotal * 100).toFixed(1) : '0';
const livePosSum = th.filter(d => d.pnl > 0).reduce((s, d) => s + d.pnl, 0);
const liveNegSum = Math.abs(th.filter(d => d.pnl < 0).reduce((s, d) => s + d.pnl, 0));
const livePf = liveNegSum > 0 ? (livePosSum / liveNegSum).toFixed(2) : '-';
// Max DD from equity curve
let eqCum = (ld.balance || 4797) - totalPnl;
let peak = eqCum;
let maxDd = 0;
for (const d of th) {
  eqCum += d.pnl;
  if (eqCum > peak) peak = eqCum;
  const dd = peak > 0 ? (peak - eqCum) / peak * 100 : 0;
  if (dd > maxDd) maxDd = dd;
}

// ═══ Equity curve chart (server-side SVG) ═══
const startFrom = (ld.balance || 4797) - totalPnl;
let cum = startFrom;
const equityPoints = [];
for (const d of th) {
  cum += d.pnl;
  equityPoints.push({ label: d.date ? d.date.slice(5) : '', value: cum });
}
const tradingDays = th.filter(d => d.trades > 0);
const wrDays = tradingDays.length > 0
  ? (tradingDays.filter(d => d.pnl > 0).length / tradingDays.length * 100).toFixed(1)
  : '0';

const SVG_W = 600, SVG_H = 220;
const PAD = { top: 20, right: 20, bottom: 30, left: 55 };
const chartW = SVG_W - PAD.left - PAD.right;
const chartH = SVG_H - PAD.top - PAD.bottom;

const vals = equityPoints.map(p => p.value);
const minVal = Math.min(...vals);
const maxVal = Math.max(...vals);
const range = maxVal - minVal || 1;
const padRange = range * 0.1;

function x(i) { return PAD.left + (i / (equityPoints.length - 1 || 1)) * chartW; }
function y(v) { return PAD.top + chartH - ((v - (minVal - padRange)) / (range + 2 * padRange)) * chartH; }

const pathD = equityPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)},${y(p.value).toFixed(1)}`).join(' ');

const yTicks = 5;
const yStep = (range + 2 * padRange) / yTicks;
const yLabels = [];
for (let i = 0; i <= yTicks; i++) {
  const v = (minVal - padRange) + i * yStep;
  yLabels.push(v);
}
const xTicks = equityPoints.filter((_, i) => i === 0 || i === equityPoints.length - 1 || i % 2 === 0);
---

<BaseLayout title="FusionGold M5 — XAUUSD ゴールド専用EA" description="XAUUSD（ゴールド）M5専用自動売買EA。ADX+4バケットスコアリング+H4ゾーンフィルター搭載。フォワードテスト中。IC Markets Raw Spread対応。物々交換で提供。">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <div class="hero-content container">

      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "FusionGold M5",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Windows/Mac (MT5)",
        "description": "ゴールド（XAUUSD）専用のMT5自動売買EA。ADX+H4ゾーン+矛盾検出エンジン搭載。",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "物々交換のみ。現金不要。" }
      }
      </script>

      <span class="hero-badge" data-i18n="hero-badge">ゴールド専用EA</span>
      <h1 data-i18n="hero-h1">FusionGold M5</h1>
      <p class="subtitle" data-i18n="hero-sub1">XAUUSD M5専用の自動売買EA — ADX+H4ゾーン+矛盾検出エンジン搭載</p>
      <p class="subtitle2" data-i18n="hero-sub2">IC Markets MT5対応 · 1日4時間集中取引 · リスク管理内蔵</p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-val">{liveDayWr}%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-winrate">勝率（フォワード）</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{totalPnl >= 0 ? '+' : ''}${Math.round(totalPnl).toLocaleString()}</span>
          <span class="hero-stat-label" data-i18n="hero-stat-profit">純利益</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{livePf}</span>
          <span class="hero-stat-label" data-i18n="hero-stat-pf">プロフィットファクター</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{maxDd.toFixed(2)}%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-dd">最大DD</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href={siteBase + '/demo/'} class="btn btn-gold" data-i18n="hero-demo-cta">デモを試す</a>
        <a href="#live-performance" class="btn btn-outline">Live Performance</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 戦略概要 ═══════════════ -->
  <section class="section" id="strategy">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="strat-title">戦略の中核 — 4バケットスコアリング</h2>
      <p class="section-sub fade-in" data-i18n="strat-sub">トレンド・モメンタム・ストラクチャー・流動性の4軸で市場を総合評価</p>

      <div class="strategy-flow fade-in" data-i18n-cluster="strategy-flow">
        <div class="sf-step"><div class="sf-num">①</div><div class="sf-text" data-i18n="strat-s1">H4ゾーン<br/><span data-i18n="strat-s1-sub">大きな流れを読む</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">②</div><div class="sf-text" data-i18n="strat-s2">ADXゲート<br/><span data-i18n="strat-s2-sub">相場の質を判定</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">③</div><div class="sf-text" data-i18n="strat-s3">4バケット<br/><span data-i18n="strat-s3-sub">スコア240以上で通過</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">④</div><div class="sf-text" data-i18n="strat-s4">矛盾検出<br/><span data-i18n="strat-s4-sub">最終確認</span></div></div>
        <div class="sf-arrow green">✓</div>
        <div class="sf-step"><div class="sf-num">⑤</div><div class="sf-text" data-i18n="strat-s5">エントリー<br/><span data-i18n="strat-s5-sub">4時間集中取引</span></div></div>
      </div>

      <div class="bucket-grid fade-in">
        <div class="bucket-card">
          <div class="bc-icon">📈</div>
          <h3 data-i18n="strat-b1-title">トレンドバケット</h3>
          <p data-i18n="strat-b1-desc">価格とEMAの関係、ADXの方向性成分（DI+/DI-）を評価。トレンドフォロー戦略の基盤。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">⚡</div>
          <h3 data-i18n="strat-b2-title">モメンタムバケット</h3>
          <p data-i18n="strat-b2-desc">MACD、RSI、価格変化率（ROC）を用いて短期的な勢いを測定。トレンドの加速・減速を検出。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">🏗️</div>
          <h3 data-i18n="strat-b3-title">ストラクチャーバケット</h3>
          <p data-i18n="strat-b3-desc">高値・安値の切り上がり/切り下がり、サポート・レジスタンスの構造を分析。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">💧</div>
          <h3 data-i18n="strat-b4-title">流動性バケット</h3>
          <p data-i18n="strat-b4-desc">取引量、スプレッド幅、セッション時間帯を評価。約定品質と取引コストを考慮。</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href={siteBase + '/strategy/'} class="text-link" data-i18n="strat-link">戦略の詳細を見る →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ライブパフォーマンス ═══════════════ -->
  <section class="section live-section" id="live-performance">
    <div class="container" style="max-width:820px;">
      <h2 class="section-title fade-in" data-i18n="live-title">ライブパフォーマンス</h2>
      <p class="live-meta fade-in"><span data-i18n="live-updated">最終更新</span>: {liveData?.updated || '--'} · IC Markets · <span data-i18n="live-liveaccount">リアル口座</span></p>

      <!-- ═══ Row 1: Key Metrics (compact horizontal) ═══ -->
      <div class="metric-row fade-in">
        <div class="metric-item">
          <div class="m-label" data-i18n="live-balance">残高</div>
          <div class="m-val">${ld.balance.toFixed(2)}</div>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <div class="m-label" data-i18n="live-daypnl">本日P&amp;L</div>
          <div class="m-val" style="color:{ld.dayPnL >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
            {ld.dayPnL >= 0 ? '+' : ''}{ld.dayPnL.toFixed(2)}
            <span class="m-sub">({ld.dayPnLPercent}%)</span>
          </div>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <div class="m-label" data-i18n="live-totalpnl">累計損益</div>
          <div class="m-val" style="color:var(--accent-green);">+${totalPnl.toFixed(2)}</div>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <div class="m-label" data-i18n="hero-stat-winrate">勝率</div>
          <div class="m-val">{liveDayWr}%</div>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <div class="m-label">PF</div>
          <div class="m-val">{livePf}</div>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <div class="m-label" data-i18n="live-status">状況</div>
          <div class="m-val"><span class={`badge-sm ${session.status === 'RUNNING' ? 'green' : 'amber'}`}>{session.status}</span></div>
        </div>
      </div>

      <!-- ═══ Row 2: Chart + History side by side ═══ -->
      <div class="live-row fade-in">
        <div class="live-chart-col">
          <div class="chart-card">
            <div class="chart-head">
              <span data-i18n="live-equity-title">📈 エクイティカーブ</span>
            </div>
            <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} style="width:100%;height:auto;display:block;" preserveAspectRatio="xMidYMid meet">
              {yLabels.map(v => (
                <line x1={PAD.left} y1={y(v)} x2={SVG_W - PAD.right} y2={y(v)} stroke="rgba(255,255,255,0.05)" stroke-width="1" />
              ))}
              {yLabels.map(v => (
                <text x={PAD.left - 8} y={y(v) + 4} text-anchor="end" fill="#6B6B80" font-size="10">${Math.round(v)}</text>
              ))}
              {xTicks.map((p, i) => (
                <text x={x(equityPoints.indexOf(p))} y={SVG_H - 6} text-anchor="middle" fill="#6B6B80" font-size="9">{p.label}</text>
              ))}
              <path d={`${pathD} L${x(equityPoints.length - 1)},${PAD.top + chartH} L${x(0)},${PAD.top + chartH} Z`} fill="rgba(212,175,55,0.08)" />
              <path d={pathD} fill="none" stroke="#D4AF37" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
              {equityPoints.map((p, i) => (
                <circle cx={x(i)} cy={y(p.value)} r="2.5" fill="#D4AF37" />
              ))}
            </svg>
            <div class="chart-stats">
              <span>{th.length}<span data-i18n="live-period-unit">日</span></span>
              <span class="dot">·</span>
              <span style="color:var(--accent-green);">{totalPnl >= 0 ? '+' : ''}${totalPnl.toFixed(2)}</span>
              <span class="dot">·</span>
              <span>{wrDays}% <span class="dim" data-i18n="live-wr-days">勝率</span></span>
              <span class="dot">·</span>
              <span class="dim">DD {maxDd.toFixed(2)}%</span>
            </div>
          </div>
        </div>
        <div class="live-trades-col">
          <div class="chart-card">
            <div class="chart-head">
              <span data-i18n="live-recent-title">⚡ 直近取引</span>
            </div>
            <div class="trades-scroll">
              <table class="trade-table">
                <thead><tr><th data-i18n="live-time">時間</th><th data-i18n="live-dir">方向</th><th data-i18n="live-lot">LOT</th><th>P&amp;L</th></tr></thead>
                <tbody>
                  {lastTrades.map(t => (
                  <tr>
                    <td class="td-time">{t.time}</td>
                    <td><span class={`tag-dir ${t.type === 'SELL' ? 'sell' : 'buy'}`}>{t.type === 'SELL' ? 'S' : 'B'}</span></td>
                    <td class="td-lot">{t.lots.toFixed(2)}</td>
                    <td class="td-pnl" style="color:{t.pnl >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
                      {t.pnl >= 0 ? '+' : ''}{t.pnl.toFixed(2)}
                    </td>
                  </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Row 3: Extra info chips (compact) ═══ -->
      <div class="live-footer fade-in">
        <span class="lf-chip"><span class="lf-lbl" data-i18n="live-positions">ポジション</span>{liveData?.account?.positions ?? 0}/{liveData?.account?.maxPositions ?? 4}</span>
        <span class="lf-chip"><span class="lf-lbl">cooldown</span><span id="cooldown-value">{session.cooldown > 0 ? session.cooldown + 's' : '—'}</span></span>
        <span class="lf-chip"><span class="lf-lbl" data-i18n="live-equity">有効証拠金</span>${(liveData?.account?.equity || ld.balance).toFixed(2)}</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════ セットアップ ═══════════════ -->
  <section class="section" style="background:var(--bg-card);">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="setup-section-title">セットアップの流れ</h2>
      <p class="section-sub fade-in" data-i18n="setup-section-sub">15〜30分で運用開始</p>

      <div class="setup-mini fade-in">
        <div class="setup-step">
          <div class="ss-num">1</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s1-title">EAファイルを受け取る</h3>
            <p data-i18n="setup-s1-desc">物々交換成立後、EAファイル（.ex5）と設定ガイドをメールでお届け。</p>
          </div>
        </div>
        <div class="setup-step">
          <div class="ss-num">2</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s2-title">MT5にインストール</h3>
            <p data-i18n="setup-s2-desc">データフォルダ内のExpertsフォルダに.ex5ファイルをコピー。XAUUSD M5チャートにドラッグ＆ドロップ。</p>
          </div>
        </div>
        <div class="setup-step">
          <div class="ss-num">3</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s3-title">自動売買を開始</h3>
            <p data-i18n="setup-s3-desc">EAプロパティでパラメータ設定後、自動売買を有効化。VPS推奨。</p>
          </div>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href={siteBase + '/setup/'} class="text-link" data-i18n="setup-link">詳細なセットアップガイド →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ リスク管理 ═══════════════ -->
  <section class="section">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="risk-title">多層リスク管理</h2>
      <p class="section-sub fade-in" data-i18n="risk-sub">口座を保護する6つの仕組み</p>
      <div class="risk-grid fade-in">
        <div class="risk-card"><div class="rc-icon">🛑</div><h3 data-i18n="risk-r1-title">日損5%リミット</h3><p data-i18n="risk-r1-desc">1日の損失が口座残高の5%に達した場合、その日の取引をすべて停止</p></div>
        <div class="risk-card"><div class="rc-icon">📉</div><h3 data-i18n="risk-r2-title">連敗フィルター</h3><p data-i18n="risk-r2-desc">連続損失発生時、市場環境の変化を待ってエントリーを休止</p></div>
        <div class="risk-card"><div class="rc-icon">⚖️</div><h3 data-i18n="risk-r3-title">Aggregate Risk</h3><p data-i18n="risk-r3-desc">全ポジションのリスク総量を監視・制御</p></div>
        <div class="risk-card"><div class="rc-icon">⏱️</div><h3 data-i18n="risk-r4-title">クールダウン</h3><p data-i18n="risk-r4-desc">取引後一定時間は新規エントリーなし。連続取引を防止</p></div>
        <div class="risk-card"><div class="rc-icon">📏</div><h3 data-i18n="risk-r5-title">固定ストップロス</h3><p data-i18n="risk-r5-desc">全エントリーに固定SL設定。予期せぬ逆行から口座を保護</p></div>
        <div class="risk-card"><div class="rc-icon">📊</div><h3 data-i18n="risk-r6-title">ポジションサイジング</h3><p data-i18n="risk-r6-desc">シグナル強度と口座残高に基づき動的にロット調整</p></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FAQ ═══════════════ -->
  <section class="section" style="background:var(--bg-card);">
    <div class="container" style="max-width:640px;">
      <h2 class="section-title fade-in" data-i18n="faq-section-title">よくある質問</h2>
      <!-- JSON-LD: FAQPage -->
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "FusionGold M5 はどのように動きますか？",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "ADXゲートで相場の質を判断し、4つの独立した視点（トレンド・モメンタム・ストラクチャー・流動性）からスコアリング。H4ゾーンフィルターで大きな流れに逆らわず、矛盾信号を検出した場合は取引をブロック。1日約4時間だけ取引を行います。"
            }
          },
          {
            "@type": "Question",
            "name": "デモ口座で試せますか？",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "はい。IC Marketsのデモ口座で無料テスト可能。またはリアルタイムの取引口座をMT5で閲覧することもできます。"
            }
          },
          {
            "@type": "Question",
            "name": "物々交換はどのように行いますか？",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "ゲーム機、日本酒、カメラレンズなど価値ある日本製品とFusionGold M5を交換。まずはお問い合わせフォームからご連絡ください。"
            }
          },
          {
            "@type": "Question",
            "name": "リスク管理はどのようになっていますか？",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "日損5%リミット、連敗フィルター、Aggregate Risk制御、クールダウン機能など、多層のリスク管理システムを内蔵しています。"
            }
          }
        ]
      }
      </script>
      <details class="faq-item fade-in" style="border-bottom:1px solid var(--border);">
        <summary class="faq-q">
          <span style="font-size:0.85rem;color:var(--gold);font-weight:700;min-width:24px;">01</span>
          <span data-i18n="faq-q1">FusionGold M5 はどのように動きますか？</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-a"><p data-i18n="faq-a1">ADXゲートで相場の質を判断し、4つの独立した視点（トレンド・モメンタム・ストラクチャー・流動性）からスコアリング。H4ゾーンフィルターで大きな流れに逆らわず、矛盾信号を検出した場合は取引をブロック。1日約4時間だけ取引を行います。</p></div>
