---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const siteBase = '/fusiongold-ea-site';

// Load live data for the forward test section
let liveData = null;
try {
  const dp = path.resolve(process.cwd(), 'public/data/ea-status.json');
  liveData = JSON.parse(fs.readFileSync(dp, 'utf-8'));
} catch {}
const ld = liveData?.account || { balance: 4797, dayPnL: 0, dayPnLPercent: 0 };
const th = liveData?.tradeHistory || [];
const totalPnl = th.reduce((s, d) => s + d.pnl, 0);
---

<BaseLayout title="FusionGold M5 — XAUUSD ゴールド専用EA" description="XAUUSD（ゴールド）M5専用自動売買EA。ADX+4バケットスコアリング+H4ゾーンフィルター搭載。回測勝率74.48%。物々交換でご利用いただけます。">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <div class="hero-content container">

      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "FusionGold M5",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Windows/Mac (MT5)",
        "description": "ゴールド（XAUUSD）専用のMT5自動売買EA。ADX+H4ゾーン+矛盾検出エンジン搭載。",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "物々交換のみ。現金不要。" }
      }
      </script>

      <span class="hero-badge" data-i18n="hero-badge">ゴールド専用EA</span>
      <h1 data-i18n="hero-h1">FusionGold M5</h1>
      <p class="subtitle" data-i18n="hero-sub1">XAUUSD M5専用の自動売買EA — ADX+H4ゾーン+矛盾検出エンジン搭載</p>
      <p class="subtitle2" data-i18n="hero-sub2">IC Markets MT5対応 · 1日4時間集中取引 · リスク管理内蔵</p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-val">74.48%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-winrate">勝率（バックテスト）</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">+$912</span>
          <span class="hero-stat-label" data-i18n="hero-stat-profit">純利益（1ヶ月）</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">1.54</span>
          <span class="hero-stat-label" data-i18n="hero-stat-pf">プロフィットファクター</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">8.61%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-dd">最大DD</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href={siteBase + '/demo/'} class="btn btn-gold" data-i18n="hero-demo-cta">デモを試す</a>
        <a href={siteBase + '/live/'} class="btn btn-outline">Live Performance</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 戦略概要 ═══════════════ -->
  <section class="section" id="strategy">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="strat-title">戦略の中核 — 4バケットスコアリング</h2>
      <p class="section-sub fade-in" data-i18n="strat-sub">トレンド・モメンタム・ストラクチャー・流動性の4軸で市場を総合評価</p>

      <div class="strategy-flow fade-in" data-i18n-cluster="strategy-flow">
        <div class="sf-step"><div class="sf-num">①</div><div class="sf-text" data-i18n="strat-s1">H4ゾーン<br/><span data-i18n="strat-s1-sub">大きな流れを読む</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">②</div><div class="sf-text" data-i18n="strat-s2">ADXゲート<br/><span data-i18n="strat-s2-sub">相場の質を判定</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">③</div><div class="sf-text" data-i18n="strat-s3">4バケット<br/><span data-i18n="strat-s3-sub">スコア240以上で通過</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">④</div><div class="sf-text" data-i18n="strat-s4">矛盾検出<br/><span data-i18n="strat-s4-sub">最終確認</span></div></div>
        <div class="sf-arrow green">✓</div>
        <div class="sf-step"><div class="sf-num">⑤</div><div class="sf-text" data-i18n="strat-s5">エントリー<br/><span data-i18n="strat-s5-sub">4時間集中取引</span></div></div>
      </div>

      <div class="bucket-grid fade-in">
        <div class="bucket-card">
          <div class="bc-icon">📈</div>
          <h3 data-i18n="strat-b1-title">トレンドバケット</h3>
          <p data-i18n="strat-b1-desc">価格とEMAの関係、ADXの方向性成分（DI+/DI-）を評価。トレンドフォロー戦略の基盤。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">⚡</div>
          <h3 data-i18n="strat-b2-title">モメンタムバケット</h3>
          <p data-i18n="strat-b2-desc">MACD、RSI、価格変化率（ROC）を用いて短期的な勢いを測定。トレンドの加速・減速を検出。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">🏗️</div>
          <h3 data-i18n="strat-b3-title">ストラクチャーバケット</h3>
          <p data-i18n="strat-b3-desc">高値・安値の切り上がり/切り下がり、サポート・レジスタンスの構造を分析。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">💧</div>
          <h3 data-i18n="strat-b4-title">流動性バケット</h3>
          <p data-i18n="strat-b4-desc">取引量、スプレッド幅、セッション時間帯を評価。約定品質と取引コストを考慮。</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href={siteBase + '/strategy/'} class="text-link" data-i18n="strat-link">戦略の詳細を見る →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ フォワードテスト ═══════════════ -->
  <section class="section">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="fw-title">フォワードテスト（リアル口座）</h2>
      <p class="section-sub fade-in" data-i18n="fw-sub">IC Markets Raw Spread · リアル口座で稼働中</p>

      <div class="fw-summary fade-in">
        <div class="fw-card">
          <div class="fw-label" data-i18n="fw-balance">口座残高</div>
          <div class="fw-val">${ld.balance.toFixed(2)}</div>
        </div>
        <div class="fw-card">
          <div class="fw-label" data-i18n="fw-daypnl">本日P&L</div>
          <div class="fw-val" style="color:{ld.dayPnL >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
            {ld.dayPnL >= 0 ? '+' : ''}{ld.dayPnL.toFixed(2)}
          </div>
        </div>
        <div class="fw-card">
          <div class="fw-label" data-i18n="fw-period">運用期間</div>
          <div class="fw-val">{th.length}<span data-i18n="fw-period-unit">日</span></div>
        </div>
        <div class="fw-card">
          <div class="fw-label" data-i18n="fw-totalpnl">累計損益</div>
          <div class="fw-val" style="color:{totalPnl >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">
            {totalPnl >= 0 ? '+' : ''}${totalPnl.toFixed(2)}
          </div>
        </div>
      </div>
      <div style="text-align:center;margin-top:16px;">
        <a href={siteBase + '/live/'} class="text-link" data-i18n="fw-link">ライブパフォーマンスを見る →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ セットアップ ═══════════════ -->
  <section class="section" style="background:var(--bg-card);">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="setup-section-title">セットアップの流れ</h2>
      <p class="section-sub fade-in" data-i18n="setup-section-sub">15〜30分で運用開始</p>

      <div class="setup-mini fade-in">
        <div class="setup-step">
          <div class="ss-num">1</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s1-title">EAファイルを受け取る</h3>
            <p data-i18n="setup-s1-desc">物々交換成立後、EAファイル（.ex5）と設定ガイドをメールでお届け。</p>
          </div>
        </div>
        <div class="setup-step">
          <div class="ss-num">2</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s2-title">MT5にインストール</h3>
            <p data-i18n="setup-s2-desc">データフォルダ内のExpertsフォルダに.ex5ファイルをコピー。XAUUSD M5チャートにドラッグ＆ドロップ。</p>
          </div>
        </div>
        <div class="setup-step">
          <div class="ss-num">3</div>
          <div class="ss-body">
            <h3 data-i18n="setup-s3-title">自動売買を開始</h3>
            <p data-i18n="setup-s3-desc">EAプロパティでパラメータ設定後、自動売買を有効化。VPS推奨。</p>
          </div>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href={siteBase + '/setup/'} class="text-link" data-i18n="setup-link">詳細なセットアップガイド →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ リスク管理 ═══════════════ -->
  <section class="section">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="risk-title">多層リスク管理</h2>
      <p class="section-sub fade-in" data-i18n="risk-sub">口座を保護する6つの仕組み</p>
      <div class="risk-grid fade-in">
        <div class="risk-card"><div class="rc-icon">🛑</div><h3 data-i18n="risk-r1-title">日損5%リミット</h3><p data-i18n="risk-r1-desc">1日の損失が口座残高の5%に達した場合、その日の取引をすべて停止</p></div>
        <div class="risk-card"><div class="rc-icon">📉</div><h3 data-i18n="risk-r2-title">連敗フィルター</h3><p data-i18n="risk-r2-desc">連続損失発生時、市場環境の変化を待ってエントリーを休止</p></div>
        <div class="risk-card"><div class="rc-icon">⚖️</div><h3 data-i18n="risk-r3-title">Aggregate Risk</h3><p data-i18n="risk-r3-desc">全ポジションのリスク総量を監視・制御</p></div>
        <div class="risk-card"><div class="rc-icon">⏱️</div><h3 data-i18n="risk-r4-title">クールダウン</h3><p data-i18n="risk-r4-desc">取引後一定時間は新規エントリーなし。連続取引を防止</p></div>
        <div class="risk-card"><div class="rc-icon">📏</div><h3 data-i18n="risk-r5-title">固定ストップロス</h3><p data-i18n="risk-r5-desc">全エントリーに固定SL設定。予期せぬ逆行から口座を保護</p></div>
        <div class="risk-card"><div class="rc-icon">📊</div><h3 data-i18n="risk-r6-title">ポジションサイジング</h3><p data-i18n="risk-r6-desc">シグナル強度と口座残高に基づき動的にロット調整</p></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FAQ ═══════════════ -->
  <section class="section" style="background:var(--bg-card);">
    <div class="container" style="max-width:640px;">
      <h2 class="section-title fade-in" data-i18n="faq-section-title">よくある質問</h2>
      <details class="faq-item fade-in" style="border-bottom:1px solid var(--border);">
        <summary class="faq-q">
          <span style="font-size:0.85rem;color:var(--gold);font-weight:700;min-width:24px;">01</span>
          <span data-i18n="faq-q1">FusionGold M5 はどのように動きますか？</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-a"><p data-i18n="faq-a1">ADXゲートで相場の質を判断し、4つの独立した視点（トレンド・モメンタム・ストラクチャー・流動性）からスコアリング。H4ゾーンフィルターで大きな流れに逆らわず、矛盾信号を検出した場合は取引をブロック。1日約4時間だけ取引を行います。</p></div>
      </details>
      <details class="faq-item fade-in" style="border-bottom:1px solid var(--border);">
        <summary class="faq-q">
          <span style="font-size:0.85rem;color:var(--gold);font-weight:700;min-width:24px;">02</span>
          <span data-i18n="faq-q2">デモ口座で試せますか？</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-a"><p data-i18n="faq-a2">はい。IC Marketsのデモ口座で14日間無料テスト可能。セットアップサポート付きです。</p></div>
      </details>
      <details class="faq-item fade-in" style="border-bottom:1px solid var(--border);">
        <summary class="faq-q">
          <span style="font-size:0.85rem;color:var(--gold);font-weight:700;min-width:24px;">03</span>
          <span data-i18n="faq-q3">物々交換はどのように行いますか？</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-a"><p data-i18n="faq-a3">ゲーム機、日本酒、カメラレンズなど価値ある日本製品とFusionGold M5を交換。まずはお問い合わせフォームからご連絡ください。</p></div>
      </details>
      <details class="faq-item fade-in" style="border-bottom:1px solid var(--border);">
        <summary class="faq-q">
          <span style="font-size:0.85rem;color:var(--gold);font-weight:700;min-width:24px;">04</span>
          <span data-i18n="faq-q4">リスク管理はどのようになっていますか？</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-a"><p data-i18n="faq-a4">日損5%リミット、連敗フィルター、Aggregate Risk制御、クールダウン機能など、多層のリスク管理システムを内蔵しています。</p></div>
      </details>
      <div style="text-align:center;margin-top:20px;">
        <a href={siteBase + '/faq/'} class="text-link" data-i18n="faq-link">すべてのFAQを見る →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 物々交換 ═══════════════ -->
  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 class="section-title fade-in" data-i18n="price-title">ご利用方法</h2>
      <p class="section-sub fade-in" data-i18n="price-sub">現金不要。物々交換のみでご提供しています。</p>

      <div class="barter-card fade-in">
        <div class="barter-price" data-i18n="p3-name">物々交換</div>
        <div class="barter-sub" data-i18n="p3-period">現金不要</div>
        <p data-i18n="p3-desc">日本製品とFusionGold M5を交換。お互いにとって価値ある取引を。</p>
        <div class="barter-includes">
          <div data-i18n="p3-f1">✓ EAファイル（.ex5）</div>
          <div data-i18n="p3-f2">✓ 設定ガイド</div>
          <div data-i18n="p3-f3">✓ メールサポート</div>
        </div>
      </div>

      <div class="barter-examples fade-in">
        <p style="font-size:0.9rem;color:var(--text-muted);margin-bottom:12px;" data-i18n="barter-text">以下のような日本製品と交換可能です。</p>
        <div class="barter-tags">
          <span>🎮 ゲーム機本体</span>
          <span>🍶 日本酒/ウイスキー</span>
          <span>📷 カメラレンズ</span>
          <span>🎎 限定フィギュア</span>
          <span>⌚ 国産時計</span>
        </div>
      </div>

      <div class="barter-cta fade-in">
        <a href={siteBase + '/contact/'} class="btn btn-gold" data-i18n="p3-cta">交換の詳細を問い合わせる</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 制作者 ═══════════════ -->
  <section class="section" style="background:var(--bg-card);">
    <div class="container" style="max-width:600px;">
      <h2 class="section-title fade-in" data-i18n="author-title">制作者について</h2>
      <div class="author-card fade-in">
        <div class="author-avatar">W</div>
        <div>
          <h3 style="color:var(--gold);font-size:1rem;margin-bottom:8px;" data-i18n="author-name">William — EA開発者・英語教育者</h3>
          <p style="font-size:0.85rem;color:var(--text-muted);line-height:1.7;" data-i18n="author-p4">Jim Simonsの数学的アプローチに影響を受けたEA開発。MITオンライン講座で統計的学習を学び、XAUUSD専用の統計的優位性（エッジ）に基づくEAを開発。廈門を拠点に、英語教育と定量取引の両軸で活動。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ファイナルCTA ═══════════════ -->
  <section class="section" style="padding-bottom:80px;">
    <div class="container" style="text-align:center;">
      <h2 style="color:var(--gold);font-size:1.3rem;margin-bottom:12px;" data-i18n="cta-title">まずはデモ口座でお試しください</h2>
      <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:20px;" data-i18n="cta-sub">14日間無料。セットアップサポート付き。</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href={siteBase + '/demo/'} class="btn btn-gold" data-i18n="cta-demo">デモを申し込む</a>
        <a href={siteBase + '/faq/'} class="btn btn-outline" data-i18n="cta-faq">FAQを見る</a>
      </div>
    </div>
  </section>

  <style>
    .hero { background: linear-gradient(135deg, #1a1a2e, #16213e); padding:60px 0 50px; text-align:center; overflow:hidden; position:relative; }
    .hero-badge { display:inline-block; padding:4px 16px; border-radius:20px; background:rgba(212,175,55,.12); color:var(--gold); font-size:0.85rem; font-weight:600; margin-bottom:20px; letter-spacing:0.5px; }
    .hero h1 { font-size:2.8rem; margin:0 0 12px; background:linear-gradient(135deg,var(--gold),#f0d060); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .subtitle { font-size:1.05rem; color:rgba(255,255,255,.7); margin-bottom:6px; }
    .subtitle2 { font-size:0.85rem; color:rgba(255,255,255,.5); margin-bottom:24px; }
    .hero-stats { display:flex; justify-content:center; gap:24px; flex-wrap:wrap; margin-bottom:28px; }
    .hero-stat { text-align:center; }
    .hero-stat-val { display:block; font-size:1.5rem; font-weight:800; color:var(--gold); }
    .hero-stat-label { display:block; font-size:0.7rem; color:rgba(255,255,255,.5); }
    .hero-actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .strategy-flow { display:flex; flex-wrap:wrap; gap:6px; align-items:center; justify-content:center; margin-bottom:28px; padding:16px; background:var(--bg-card); border-radius:var(--radius); border:1px solid var(--border); }
    .sf-step { display:flex; align-items:center; gap:6px; }
    .sf-num { width:24px; height:24px; border-radius:50%; background:var(--gold); color:#111; font-weight:800; font-size:0.7rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .sf-text { font-size:0.8rem; color:var(--text); line-height:1.2; }
    .sf-text span { font-size:0.65rem; color:var(--text-muted); }
    .sf-arrow { font-size:1rem; color:var(--gold); font-weight:700; }
    .sf-arrow.green { color:var(--accent-green); }
    .bucket-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:10px; }
    .bucket-card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:18px; }
    .bc-icon { font-size:1.4rem; margin-bottom:6px; }
    .bucket-card h3 { font-size:0.9rem; color:var(--gold); margin-bottom:6px; }
    .bucket-card p { font-size:0.8rem; color:var(--text-muted); line-height:1.6; margin:0; }
    .bt-summary { display:flex; justify-content:center; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
    .bt-item { text-align:center; padding:10px 16px; background:var(--bg); border-radius:8px; border:1px solid var(--border); min-width:80px; }
    .bt-num { display:block; font-size:1.2rem; font-weight:700; color:var(--text); }
    .bt-lbl { display:block; font-size:0.65rem; color:var(--text-muted); margin-top:2px; }
    .bt-chart-wrap { position:relative; height:220px; max-width:600px; margin:0 auto; }
