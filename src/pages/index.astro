import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const siteBase = '/fusiongold-ea-site';

// Load live data for the forward test section
let liveData = null;
try {
  const dp = path.resolve(process.cwd(), 'public/data/ea-status.json');
  liveData = JSON.parse(fs.readFileSync(dp, 'utf-8'));
} catch {}
const ld = liveData?.account || { balance: 4797, dayPnL: 0, dayPnLPercent: 0 };
const session = liveData?.session || { status: 'WAITING', cooldown: 0 };
const th = liveData?.tradeHistory || [];
const lastTrades = liveData?.lastTrades || [];
const totalPnl = th.reduce((s, d) => s + d.pnl, 0);

// Compute live stats from forward test data
const liveTrades = th.reduce((s, d) => s + d.trades, 0);
const liveWinDays = th.filter(d => d.pnl > 0).length;
const liveLossDays = th.filter(d => d.pnl < 0).length;
const liveWinDaysTotal = liveWinDays + liveLossDays;
const liveDayWr = liveWinDaysTotal > 0 ? (liveWinDays / liveWinDaysTotal * 100).toFixed(1) : '0';
const livePosSum = th.filter(d => d.pnl > 0).reduce((s, d) => s + d.pnl, 0);
const liveNegSum = Math.abs(th.filter(d => d.pnl < 0).reduce((s, d) => s + d.pnl, 0));
const livePf = liveNegSum > 0 ? (livePosSum / liveNegSum).toFixed(2) : '-';
// Max DD from equity curve
let eqCum = (ld.balance || 4797) - totalPnl;
let peak = eqCum;
let maxDd = 0;
for (const d of th) {
  eqCum += d.pnl;
  if (eqCum > peak) peak = eqCum;
  const dd = peak > 0 ? (peak - eqCum) / peak * 100 : 0;
  if (dd > maxDd) maxDd = dd;
}

// ═══ Equity curve chart (server-side SVG) ═══
const startFrom = (ld.balance || 4797) - totalPnl;
let cum = startFrom;
const equityPoints = [];
for (const d of th) {
  cum += d.pnl;
  equityPoints.push({ label: d.date ? d.date.slice(5) : '', value: cum });
}
const tradingDays = th.filter(d => d.trades > 0);
const wrDays = tradingDays.length > 0
  ? (tradingDays.filter(d => d.pnl > 0).length / tradingDays.length * 100).toFixed(1)
  : '0';

const SVG_W = 600, SVG_H = 220;
const PAD = { top: 20, right: 20, bottom: 30, left: 55 };
const chartW = SVG_W - PAD.left - PAD.right;
const chartH = SVG_H - PAD.top - PAD.bottom;

const vals = equityPoints.map(p => p.value);
const minVal = Math.min(...vals);
const maxVal = Math.max(...vals);
const range = maxVal - minVal || 1;
const padRange = range * 0.1;

function x(i) { return PAD.left + (i / (equityPoints.length - 1 || 1)) * chartW; }
function y(v) { return PAD.top + chartH - ((v - (minVal - padRange)) / (range + 2 * padRange)) * chartH; }

const pathD = equityPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)},${y(p.value).toFixed(1)}`).join(' ');

const yTicks = 5;
const yStep = (range + 2 * padRange) / yTicks;
const yLabels = [];
for (let i = 0; i <= yTicks; i++) {
  const v = (minVal - padRange) + i * yStep;
  yLabels.push(v);
}
const xTicks = equityPoints.filter((_, i) => i === 0 || i === equityPoints.length - 1 || i % 2 === 0);
---

<BaseLayout title="FusionGold M5 — XAUUSD ゴールド専用EA" description="XAUUSD（ゴールド）M5専用自動売買EA。ADX+4バケットスコアリング+H4ゾーンフィルター搭載。フォワードテスト中。IC Markets Raw Spread対応。物々交換で提供。">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <div class="hero-content container">

      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "FusionGold M5",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Windows/Mac (MT5)",
        "description": "ゴールド（XAUUSD）専用のMT5自動売買EA。ADX+H4ゾーン+矛盾検出エンジン搭載。",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "JPY", "description": "物々交換のみ。現金不要。" }
      }
      </script>

      <span class="hero-badge" data-i18n="hero-badge">ゴールド専用EA</span>
      <h1 data-i18n="hero-h1">FusionGold M5</h1>
      <p class="subtitle" data-i18n="hero-sub1">XAUUSD M5専用の自動売買EA — ADX+H4ゾーン+矛盾検出エンジン搭載</p>
      <p class="subtitle2" data-i18n="hero-sub2">IC Markets MT5対応 · 1日4時間集中取引 · リスク管理内蔵</p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-val">{liveDayWr}%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-winrate">勝率（フォワード）</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{totalPnl >= 0 ? '+' : ''}${Math.round(totalPnl).toLocaleString()}</span>
          <span class="hero-stat-label" data-i18n="hero-stat-profit">純利益</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{livePf}</span>
          <span class="hero-stat-label" data-i18n="hero-stat-pf">プロフィットファクター</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{maxDd.toFixed(2)}%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-dd">最大DD</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href={siteBase + '/demo/'} class="btn btn-gold" data-i18n="hero-demo-cta">デモを試す</a>
        <a href="#live-performance" class="btn btn-outline">Live Performance</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ 4バケット戦略 ═══════════════ -->
  <section class="section" id="strategy" style="text-align:center;">
    <div class="container">
      <h2 class="section-title fade-in" data-i18n="strat-title">戦略の中核 — 4バケットスコアリング</h2>
      <p class="section-sub fade-in" data-i18n="strat-sub">トレンド・モメンタム・ストラクチャー・流動性の4軸で市場を総合評価</p>

      <div class="strategy-flow fade-in" data-i18n-cluster="strategy-flow">
        <div class="sf-step"><div class="sf-num">①</div><div class="sf-text" data-i18n="strat-s1">H4ゾーン<br/><span data-i18n="strat-s1-sub">大きな流れを読む</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">②</div><div class="sf-text" data-i18n="strat-s2">ADXゲート<br/><span data-i18n="strat-s2-sub">相場の質を判定</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">③</div><div class="sf-text" data-i18n="strat-s3">4バケット<br/><span data-i18n="strat-s3-sub">スコア240以上で通過</span></div></div>
        <div class="sf-arrow">→</div>
        <div class="sf-step"><div class="sf-num">④</div><div class="sf-text" data-i18n="strat-s4">矛盾検出<br/><span data-i18n="strat-s4-sub">最終確認</span></div></div>
        <div class="sf-arrow green">✓</div>
        <div class="sf-step"><div class="sf-num">⑤</div><div class="sf-text" data-i18n="strat-s5">エントリー<br/><span data-i18n="strat-s5-sub">4時間集中取引</span></div></div>
      </div>

      <div class="bucket-grid fade-in">
        <div class="bucket-card">
          <div class="bc-icon">📈</div>
          <h3 data-i18n="strat-b1-title">トレンドバケット</h3>
          <p data-i18n="strat-b1-desc">価格とEMAの関係、ADXの方向性成分（DI+/DI-）を評価。トレンドフォロー戦略の基盤。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">⚡</div>
          <h3 data-i18n="strat-b2-title">モメンタムバケット</h3>
          <p data-i18n="strat-b2-desc">MACD、RSI、価格変化率（ROC）を用いて短期的な勢いを測定。トレンドの加速・減速を検出。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">🏗️</div>
          <h3 data-i18n="strat-b3-title">ストラクチャーバケット</h3>
          <p data-i18n="strat-b3-desc">高値・安値の切り上がり/切り下がり、サポート・レジスタンスの構造を分析。</p>
        </div>
        <div class="bucket-card">
          <div class="bc-icon">💧</div>
          <h3 data-i18n="strat-b4-title">流動性バケット</h3>
          <p data-i18n="strat-b4-desc">取引量、スプレッド幅、セッション時間帯を評価。約定品質と取引コストを考慮。</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href={siteBase + '/strategy/'} class="text-link" data-i18n="strat-link">戦略の詳細を見る →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ライブパフォーマンス（HERO 同款） ═══════════════ -->
  <section class="hero" id="live-performance" style="padding:60px 0 50px;">
    <div class="hero-content container">
      <h2 style="font-size:1.5rem;margin:0 0 4px;background:linear-gradient(135deg,var(--gold),#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;" data-i18n="live-title">ライブパフォーマンス</h2>
      <p style="color:rgba(255,255,255,.45);font-size:0.8rem;margin:-10px 0 22px;"><span data-i18n="live-updated">最終更新</span>: {liveData?.updated || '--'} · IC Markets · <span data-i18n="live-liveaccount">リアル口座</span></p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-val">${ld.balance.toFixed(2)}</span>
          <span class="hero-stat-label" data-i18n="live-balance">残高</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val" style="color:{ld.dayPnL >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}">{ld.dayPnL >= 0 ? '+' : ''}{ld.dayPnL.toFixed(2)}</span>
          <span class="hero-stat-label" data-i18n="live-daypnl">本日P&amp;L</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val" style="color:var(--accent-green);">+${totalPnl.toFixed(2)}</span>
          <span class="hero-stat-label" data-i18n="live-totalpnl">累計損益</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{liveDayWr}%</span>
          <span class="hero-stat-label" data-i18n="hero-stat-winrate">勝率</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val">{livePf}</span>
          <span class="hero-stat-label">PF</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-val"><span style="font-size:0.9rem;padding:2px 10px;border-radius:8px;background:{session.status === 'RUNNING' ? 'rgba(46,204,113,0.2)' : 'rgba(241,196,15,0.2)'};color:{session.status === 'RUNNING' ? '#2ecc71' : '#f1c40f'};font-weight:600;">{session.status}</span></span>
          <span class="hero-stat-label" data-i18n="live-status">状況</span>
        </div>
      </div>

      <div style="display:flex;gap:14px;margin-top:20px;justify-content:center;flex-wrap:wrap;">
        <div style="flex:3;min-width:260px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px;backdrop-filter:blur(4px);text-align:left;">
          <div style="font-size:0.85rem;color:var(--gold);font-weight:600;margin-bottom:8px;" data-i18n="live-equity-title">📈 エクイティカーブ</div>
          <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} style="width:100%;height:auto;display:block;" preserveAspectRatio="xMidYMid meet">
            {yLabels.map(v => (<line x1={PAD.left} y1={y(v)} x2={SVG_W - PAD.right} y2={y(v)} stroke="rgba(255,255,255,0.05)" stroke-width="1" />))}
            {yLabels.map(v => (<text x={PAD.left - 8} y={y(v) + 4} text-anchor="end" fill="#6B6B80" font-size="10">${Math.round(v)}</text>))}
            {xTicks.map((p, i) => (<text x={x(equityPoints.indexOf(p))} y={SVG_H - 6} text-anchor="middle" fill="#6B6B80" font-size="9">{p.label}</text>))}
            <path d={`${pathD} L${x(equityPoints.length - 1)},${PAD.top + chartH} L${x(0)},${PAD.top + chartH} Z`} fill="rgba(212,175,55,0.08)" />
            <path d={pathD} fill="none" stroke="#D4AF37" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
            {equityPoints.map((p, i) => (<circle cx={x(i)} cy={y(p.value)} r="2.5" fill="#D4AF37" />))}
          </svg>
          <div style="display:flex;gap:4px;align-items:center;justify-content:center;flex-wrap:wrap;margin-top:6px;font-size:0.7rem;color:rgba(255,255,255,.5);">
            <span>{th.length}<span data-i18n="live-period-unit">日</span></span><span style="color:rgba(255,255,255,.12);font-size:0.4rem;">·</span>
            <span style="color:var(--accent-green);">{totalPnl >= 0 ? '+' : ''}${totalPnl.toFixed(2)}</span><span style="color:rgba(255,255,255,.12);font-size:0.4rem;">·</span>
            <span>{wrDays}% 勝率</span><span style="color:rgba(255,255,255,.12);font-size:0.4rem;">·</span>
            <span>DD {maxDd.toFixed(2)}%</span>
          </div>
        </div>
        <div style="flex:2;min-width:200px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px;backdrop-filter:blur(4px);text-align:left;">
          <div style="font-size:0.85rem;color:var(--gold);font-weight:600;margin-bottom:8px;" data-i18n="live-recent-title">⚡ 直近取引</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.78rem;">
              <thead><tr><th style="color:rgba(255,255,255,.35);font-weight:500;font-size:0.62rem;padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.06);text-transform:uppercase;letter-spacing:0.3px;">時間</th><th style="color:rgba(255,255,255,.35);font-weight:500;font-size:0.62rem;padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.06);text-transform:uppercase;letter-spacing:0.3px;" data-i18n="live-dir">方向</th><th style="color:rgba(255,255,255,.35);font-weight:500;font-size:0.62rem;padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.06);text-transform:uppercase;letter-spacing:0.3px;">LOT</th><th style="color:rgba(255,255,255,.35);font-weight:500;font-size:0.62rem;padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.06);text-transform:uppercase;letter-spacing:0.3px;">P&amp;L</th></tr></thead>
              <tbody>
                {lastTrades.map(t => (
                <tr>
                  <td style="font-size:0.68rem;color:rgba(255,255,255,.4);padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.03);white-space:nowrap;">{t.time}</td>
                  <td style="padding:4px 6px;text-align:center;border-bottom:1px solid rgba(255,255,255,.03);"><span style="display:inline-block;padding:0 6px;border-radius:6px;font-size:0.62rem;font-weight:700;line-height:1.5;background:{t.type === 'SELL' ? 'rgba(231,76,60,0.2)' : 'rgba(46,204,113,0.2)'};color:{t.type === 'SELL' ? '#e74c3c' : '#2ecc71'};">{t.type === 'SELL' ? 'S' : 'B'}</span></td>
