---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const jpPosts = await getCollection('blog');
const enPosts = await getCollection('blog-en');

// Build slug map: slug → { jp, en }
const enMap = {};
for (const p of enPosts) enMap[p.id] = p;

const allPosts = jpPosts
  .map(p => ({
    slug: p.id.replace(/\.(md|mdx)$/, ''),
    jp: p,
    en: enMap[p.id] || null,
  }))
  .sort((a, b) => b.jp.data.pubDate.valueOf() - a.jp.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="金色 | FusionGold M5" description="FusionGold M5 ブログ — XAUUSD分析、EAトレード戦略。">

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://williamlinknight.github.io{base}/"},
      {"@type": "ListItem", "position": 2, "name": "ブログ"}
    ]
  }
  </script>

  <div class="container" style="padding-top:40px;padding-bottom:60px;">
    <h1 style="color:var(--gold);margin-bottom:8px;" data-i18n="blog-title">ブログ</h1>
    <p style="color:var(--text-muted);margin-bottom:32px;" data-i18n="blog-sub">XAUUSD分析、トレード戦略、EA最新情報</p>

    {allPosts.length === 0 && (
      <div style="text-align:center;padding:80px 0;color:var(--text-muted);">
        <p style="font-size:1.2rem;margin-bottom:8px;" data-i18n="blog-empty">まだ記事がありません</p>
        <p data-i18n="blog-empty2">近日公開予定</p>
      </div>
    )}

    <div style="display:grid;gap:20px;">
      {allPosts.map((post) => (
        <article style="background:var(--bg-card);border-radius:var(--radius);padding:24px;border:1px solid var(--border);">
          <a href={`${base}/blog/${post.slug}/`} style="text-decoration:none;">
            <h2 style="color:var(--text-heading);font-size:1.1rem;margin-bottom:8px;">
              <span class="lang-jp">{post.jp.data.title}</span>
              {post.en && <span class="lang-en">{post.en.data.title}</span>}
            </h2>
          </a>
          <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;">
            <time data-date={post.jp.data.pubDate.toISOString()}>{post.jp.data.pubDate.toLocaleDateString('ja-JP')}</time>
            {post.jp.data.tags && post.jp.data.tags.map(t => <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:rgba(212,175,55,.1);color:var(--gold);font-size:0.75rem;margin-left:8px;" class="lang-jp">{t}</span>)}
            {post.en && post.en.data.tags && post.en.data.tags.map(t => <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:rgba(212,175,55,.1);color:var(--gold);font-size:0.75rem;margin-left:8px;" class="lang-en">{t}</span>)}
          </div>
          <p style="font-size:0.9rem;color:var(--text-muted);">
            <span class="lang-jp">{post.jp.data.description}</span>
            {post.en && <span class="lang-en">{post.en.data.description}</span>}
          </p>
          <a href={`${base}/blog/${post.slug}/`} style="display:inline-flex;align-items:center;gap:6px;color:var(--gold);font-weight:500;font-size:0.9rem;margin-top:12px;"><span data-i18n="blog-readmore">続きを読む →</span></a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
