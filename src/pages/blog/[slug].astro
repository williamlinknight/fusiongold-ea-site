---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const jpPosts = await getCollection('blog');
  const enPosts = await getCollection('blog-en');

  const enMap = {};
  for (const p of enPosts) enMap[p.id] = p;

  return jpPosts.map((post) => {
    const slug = post.id.replace(/\.(md|mdx)$/, '');
    const en = enMap[post.id] || null;
    return {
      params: { slug },
      props: { jp: post, en },
    };
  });
}

const { jp: jpPost, en: enPost } = Astro.props;
const jpContent = jpPost.rendered?.html ?? jpPost.body;
const enContent = enPost ? (enPost.rendered?.html ?? enPost.body) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pubDateISO = jpPost.data.pubDate.toISOString();
const pageTitle = jpPost.data.title + ' | FusionGold M5';
const pageDesc = jpPost.data.description;
---

<BaseLayout title={pageTitle} description={pageDesc}>

  <!-- JSON-LD: Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": jpPost.data.title,
    "description": jpPost.data.description,
    "datePublished": pubDateISO,
    "author": {
      "@type": "Person",
      "name": jpPost.data.author || 'William'
    },
    "publisher": {
      "@type": "Organization",
      "name": "FusionGold M5"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://williamlinknight.github.io/fusiongold-ea-site/blog/${jpPost.id.replace(/\.(md|mdx)$/, '')}/`
    }
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://williamlinknight.github.io/fusiongold-ea-site/"},
      {"@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://williamlinknight.github.io/fusiongold-ea-site/blog/"},
      {"@type": "ListItem", "position": 3, "name": "{jpPost.data.title}"}
    ]
  }
  </script>

  <article style="padding:40px 0 60px;">
    <div class="container" style="max-width:720px;">
      <a href={`${base}/blog/`} style="color:var(--text-muted);font-size:0.85rem;" data-i18n="blog-back">← ブログ一覧</a>
      <h1 style="color:var(--gold);margin:16px 0 8px;font-size:1.5rem;">
        <span class="lang-jp">{jpPost.data.title}</span>
        {enPost && <span class="lang-en">{enPost.data.title}</span>}
      </h1>
      <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:24px;">
        <time data-date={pubDateISO}>{new Date(jpPost.data.pubDate).toLocaleDateString('ja-JP')}</time>
        {jpPost.data.author && <span class="lang-jp"> · {jpPost.data.author}</span>}
        {enPost && enPost.data.author && <span class="lang-en"> · {enPost.data.author}</span>}
        {jpPost.data.tags && jpPost.data.tags.map(t => <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:rgba(212,175,55,.1);color:var(--gold);font-size:0.75rem;margin-left:8px;" class="lang-jp">{t}</span>)}
        {enPost && enPost.data.tags && enPost.data.tags.map(t => <span style="display:inline-block;padding:2px 8px;border-radius:10px;background:rgba(212,175,55,.1);color:var(--gold);font-size:0.75rem;margin-left:8px;" class="lang-en">{t}</span>)}
      </div>
      <!-- JP body -->
      <div class="post-content lang-jp" set:html={jpContent} />
      <!-- EN body (hidden by CSS in JP mode) -->
      {enContent && <div class="post-content lang-en" set:html={enContent} />}
    </div>
  </article>
  <style>
    .post-content { line-height: 1.9; font-size: 0.95rem; }
    .post-content h2 { color: var(--gold); font-size: 1.2rem; margin: 28px 0 12px; }
    .post-content h3 { font-size: 1.05rem; margin: 20px 0 8px; }
    .post-content p { margin-bottom: 16px; }
    .post-content code { background: var(--bg-card); padding: 2px 8px; border-radius: 4px; font-size: 0.85rem; }
    .post-content img { max-width: 100%; border-radius: var(--radius); }
    .post-content blockquote { border-left: 3px solid var(--gold); padding-left: 16px; color: var(--text-muted); margin: 16px 0; }
    .post-content table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.85rem; }
    .post-content th, .post-content td { border: 1px solid var(--border); padding: 6px 10px; text-align: left; }
    .post-content th { background: rgba(212,175,55,.1); color: var(--gold); }
  </style>
</BaseLayout>
