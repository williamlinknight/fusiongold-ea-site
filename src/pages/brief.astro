---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="デイリー分析 | FusionGold M5" description="XAUUSD デイリーテクニカル分析。HMMレジーム、BB、MACD、推奨戦略。">

  <div class="container" style="padding-top:40px;padding-bottom:60px;">
    <h1 style="color:var(--gold);margin-bottom:8px;" data-i18n="brief-title">XAUUSD デイリー分析</h1>
    <p style="color:var(--text-muted);margin-bottom:32px;" data-i18n="brief-sub">最新テクニカル分析 + HMMレジーム — 毎営業日更新</p>

    <!-- Brief Cards -->
    <div class="perf-table-wrap" style="margin-bottom:16px;">
      <div class="brief-cards">
        <div class="brief-card"><div class="label" data-i18n="brief-price">現在値</div><div class="value gold big">$4,030</div><div class="sub red">▼ -$0.05 (-0.05%)</div></div>
        <div class="brief-card"><div class="label" data-i18n="brief-hmm">HMM</div><div class="value gold">📉 トレンド下降</div><div class="sub" data-i18n="brief-conf">確信度 0%</div></div>
        <div class="brief-card"><div class="label" data-i18n="brief-signal">シグナル</div><div class="value green">NEUTRAL</div><div class="sub">Score: 0/3</div></div>
        <div class="brief-card"><div class="label" data-i18n="brief-bb">BB</div><div class="value gold">0.94%</div><div class="sub">収縮中</div></div>
        <div class="brief-card"><div class="label" data-i18n="brief-macd">MACD</div><div class="value red">-3.3</div><div class="sub">上昇中</div></div>
      </div>
    </div>

    <!-- Resistance / Support -->
    <div class="perf-table-wrap" style="margin-bottom:16px;">
      <table class="perf-table">
        <thead><tr>
          <th data-i18n="brief-resist">レジスタンス</th><th></th><th data-i18n="brief-support">サポート</th>
        </tr></thead>
        <tbody>
          <tr><td class="highlight-red">$4,004</td><td>BB上限 / 直近高値</td><td class="highlight">$3,972</td></tr>
          <tr><td class="highlight-red">$4,004</td><td>BB上轨</td><td class="highlight">$3,988</td></tr>
          <tr><td style="color:var(--text-muted);">$3,988</td><td>BB中央線</td><td style="color:var(--text-muted);">$4,109</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Strategy -->
    <div class="perf-table-wrap">
      <table class="perf-table">
        <thead><tr>
          <th data-i18n="brief-strat">推奨戦略</th>
          <th data-i18n="brief-entry">エントリー</th>
          <th data-i18n="brief-tp">利確</th>
          <th data-i18n="brief-sl">損切</th>
        </tr></thead>
        <tbody><tr>
          <td style="color:var(--gold);font-weight:600;">NEUTRAL</td>
          <td>$3,989 – $4,012</td>
          <td>$4,012</td>
          <td style="color:var(--accent-red);">$4,123</td>
        </tr></tbody>
      </table>
      <p style="margin-top:12px;font-size:0.8rem;color:var(--text-muted);" data-i18n="brief-update">最終更新: 2026-07-17 19:04 BJT</p>
    </div>

    <p style="text-align:center;color:var(--text-muted);font-size:0.85rem;padding:20px;" data-i18n="brief-note">※ データは毎営業日19:00 BJTに自動更新されます</p>
  </div>

  <style>
    .brief-card .green { color: var(--accent-green); }
    .brief-card .red { color: var(--accent-red); }
  </style>
</BaseLayout>
